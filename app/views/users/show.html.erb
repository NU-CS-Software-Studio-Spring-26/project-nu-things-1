<% display = display_user_name(@user).presence || "Member" %>
<% content_for :title, page_title("#{display} — Profile") %>

<h2 class="h2 mb-1 text-purple"><%= display %></h2>
<p class="text-muted small mb-1">Profile — posts on <%= brand_name %>.</p>
<div class="mb-4">
  <p class="small text-muted text-uppercase mb-1">User reputation</p>
  <%= render "application/user_reputation_score", user: @user, show_breakdown: show_user_reputation_breakdown?(@user) %>
  <p class="small text-muted mb-0">Based on exchange ratings from completed handoffs and marketplace purchases. Same score on rentals and marketplace.</p>
</div>

<% if signed_in? && current_user != @user %>
  <div class="mb-4">
    <% if current_user.blocking?(@user) %>
      <%= button_to "Unblock user", user_block_path(@user), method: :delete, class: "btn btn-sm btn-outline-secondary" %>
    <% else %>
      <%= button_to "Block user", user_block_path(@user), method: :post,
                    class: "btn btn-sm btn-outline-danger",
                    form: { data: { turbo_confirm: "Block this user? They won't be able to send new messages or see your listings." } } %>
    <% end %>
  </div>
<% end %>

<div class="d-flex flex-column gap-5">

  <%= render "users/reputation_ratings_received" %>

  <%# Lost items (authored) %>
  <section>
    <h2 class="h5 text-muted text-uppercase mb-3">Lost items posted</h2>
    <% if @authored_lost_items.any? %>
      <ul class="list-group nu-card rounded">
        <% @authored_lost_items.each do |item| %>
          <li class="list-group-item d-flex flex-column flex-sm-row gap-3 align-items-sm-start">
            <div class="flex-shrink-0">
              <% if item.listing_image_available? %>
                <%= listing_image_tag item, alt: item.title, class: "rounded nu-profile-thumb" %>
              <% else %>
                <%= render "application/listing_image_placeholder", profile_thumb: true, extra_classes: "rounded nu-listing-image-placeholder--tiny" %>
              <% end %>
            </div>
            <div class="flex-grow-1 min-w-0">
              <%= link_to item.title, item, class: "fw-semibold text-purple text-decoration-none" %>
              <div class="small text-muted mt-1"><%= item.location_lost %> · <%= item.date_lost&.strftime("%b %-d, %Y") %></div>
              <span class="badge rounded-pill <%= lost_status_badge_class(item.status) %> mt-2"><%= item.status.titleize %></span>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No lost item posts yet.</p>
    <% end %>
  </section>

  <%# Found items posted (authored as finder) %>
  <section>
    <h2 class="h5 text-muted text-uppercase mb-3">Found items posted</h2>
    <p class="small text-muted mb-3">Posts this person submitted as the finder.</p>
    <% if @authored_found_items.any? %>
      <ul class="list-group nu-card rounded">
        <% @authored_found_items.each do |item| %>
          <li class="list-group-item d-flex flex-column flex-sm-row gap-3 align-items-sm-start">
            <div class="flex-shrink-0">
              <% if item.listing_image_available? %>
                <%= listing_image_tag item, alt: item.title, class: "rounded nu-profile-thumb" %>
              <% else %>
                <%= render "application/listing_image_placeholder", profile_thumb: true, extra_classes: "rounded nu-listing-image-placeholder--tiny" %>
              <% end %>
            </div>
            <div class="flex-grow-1 min-w-0">
              <%= link_to item.title, item, class: "fw-semibold text-purple text-decoration-none" %>
              <div class="small text-muted mt-1"><%= item.location_found %> · <%= item.date_found&.strftime("%b %-d, %Y") %></div>
              <span class="badge rounded-pill <%= found_status_badge_class(item.status) %> mt-2"><%= item.status.titleize %></span>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No found item posts yet.</p>
    <% end %>
  </section>

  <%# Marketplace %>
  <section>
    <h2 class="h5 text-muted text-uppercase mb-3">Marketplace listings</h2>
    <% if @authored_marketplace_listings.any? %>
      <ul class="list-group nu-card rounded">
        <% @authored_marketplace_listings.each do |listing| %>
          <li class="list-group-item d-flex flex-column flex-sm-row gap-3 align-items-sm-start">
            <div class="flex-shrink-0">
              <% if listing.listing_image_available? %>
                <%= listing_image_tag listing, alt: listing.title, class: "rounded nu-profile-thumb" %>
              <% else %>
                <%= render "application/listing_image_placeholder", profile_thumb: true, extra_classes: "rounded nu-listing-image-placeholder--tiny" %>
              <% end %>
            </div>
            <div class="flex-grow-1 min-w-0">
              <%= link_to listing.title, listing, class: "fw-semibold text-purple text-decoration-none" %>
              <div class="small text-muted mt-1"><%= listing.location %> · <%= listing.category_label %></div>
              <span class="badge <%= marketplace_listing_type_badge_class(listing.listing_type) %> mt-2"><%= listing.listing_type == "wanted" ? "Wanted" : "For sale" %></span>
              <% if listing.status.present? %>
                <span class="badge text-bg-light border mt-2 ms-1"><%= listing.status.titleize %></span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No marketplace listings yet.</p>
    <% end %>
  </section>

  <%# Rentals %>
  <section>
    <h2 class="h5 text-muted text-uppercase mb-3">Rental listings</h2>
    <% if @authored_rental_items.any? %>
      <ul class="list-group nu-card rounded">
        <% @authored_rental_items.each do |item| %>
          <li class="list-group-item d-flex flex-column flex-sm-row gap-3 align-items-sm-start">
            <div class="flex-shrink-0">
              <% if item.listing_image_available? %>
                <%= listing_image_tag item, alt: item.title, class: "rounded nu-profile-thumb" %>
              <% else %>
                <%= render "application/listing_image_placeholder", profile_thumb: true, extra_classes: "rounded nu-listing-image-placeholder--tiny" %>
              <% end %>
            </div>
            <div class="flex-grow-1 min-w-0">
              <%= link_to item.title, item, class: "fw-semibold text-primary text-decoration-none" %>
              <div class="small text-muted mt-1"><%= item.location %></div>
              <span class="text-primary fw-semibold small mt-2 d-inline-block"><%= format_rental_rate(item) %></span>
              <% if item.status.present? %>
                <span class="badge text-bg-light border mt-2 ms-2"><%= item.status.titleize %></span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No rental listings yet.</p>
    <% end %>
  </section>

  <%# Rental bookings requested %>
  <section>
    <h2 class="h5 text-muted text-uppercase mb-3">Rental bookings requested</h2>
    <p class="small text-muted mb-3">Items this person has asked to rent from others.</p>
    <% if @requested_rental_bookings.any? %>
      <ul class="list-group nu-card rounded">
        <% @requested_rental_bookings.each do |booking| %>
          <% item = booking.rental_item %>
          <li class="list-group-item d-flex flex-column flex-sm-row gap-3 align-items-sm-start">
            <div class="flex-shrink-0">
              <% if item.listing_image_available? %>
                <%= listing_image_tag item, alt: item.title, class: "rounded nu-profile-thumb" %>
              <% else %>
                <%= render "application/listing_image_placeholder", profile_thumb: true, extra_classes: "rounded nu-listing-image-placeholder--tiny" %>
              <% end %>
            </div>
            <div class="flex-grow-1 min-w-0">
              <%= link_to item.title, item, class: "fw-semibold text-primary text-decoration-none" %>
              <div class="small text-muted mt-1">
                <%= booking.start_date.strftime("%b %-d, %Y") %> – <%= booking.end_date.strftime("%b %-d, %Y") %>
                · <%= item.location %>
              </div>
              <span class="badge <%= booking_status_badge_class(booking.status) %> mt-2"><%= booking.status.titleize %></span>
              <% if booking.status == "confirmed" %>
                <span class="badge text-bg-light border mt-2 ms-1"><%= booking_exchange_summary(booking) %></span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No rental requests yet.</p>
    <% end %>
  </section>

  <%# Claimed found items %>
  <section>
    <h2 class="h5 text-muted text-uppercase mb-3">Found items marked claimed</h2>
    <p class="small text-muted mb-3">Items they marked as claimed on the board.</p>
    <% if @claimed_found_items.any? %>
      <ul class="list-group nu-card rounded">
        <% @claimed_found_items.each do |item| %>
          <li class="list-group-item d-flex flex-column flex-sm-row gap-3 align-items-sm-start">
            <div class="flex-shrink-0">
              <% if item.listing_image_available? %>
                <%= listing_image_tag item, alt: item.title, class: "rounded nu-profile-thumb" %>
              <% else %>
                <%= render "application/listing_image_placeholder", profile_thumb: true, extra_classes: "rounded nu-listing-image-placeholder--tiny" %>
              <% end %>
            </div>
            <div class="flex-grow-1 min-w-0">
              <%= link_to item.title, item, class: "fw-semibold text-purple text-decoration-none" %>
              <div class="small text-muted mt-1"><%= item.location_found %> · <%= item.date_found&.strftime("%b %-d, %Y") %></div>
              <span class="badge rounded-pill <%= found_status_badge_class(item.status) %> mt-2"><%= item.status.titleize %></span>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No claimed items yet.</p>
    <% end %>
  </section>

</div>

<% if signed_in? && current_user == @user %>
  <div class="nu-profile-blocked mt-4 pt-3 border-top">
    <p class="mb-0 text-center">
      <button type="button"
              class="btn btn-link btn-sm nu-profile-blocked-toggle"
              data-bs-toggle="collapse"
              data-bs-target="#profileBlockedUsers"
              aria-expanded="false"
              aria-controls="profileBlockedUsers">
        Blocked users<% if @blocked_users.any? %> (<%= @blocked_users.size %>)<% end %>
      </button>
    </p>
    <div class="collapse" id="profileBlockedUsers">
      <div class="nu-profile-blocked-panel pt-2 pb-1">
        <p class="small text-muted text-center mb-3">People you've blocked can't send new messages or see your listings. Past chat history stays visible, but neither of you can reply.</p>
        <% if @blocked_users.any? %>
          <ul class="list-group nu-card rounded nu-profile-blocked-list">
            <% @blocked_users.each do |blocked_user| %>
              <li class="list-group-item d-flex flex-column flex-sm-row gap-2 align-items-sm-center justify-content-between py-2">
                <div class="min-w-0">
                  <%= link_to display_user_name(blocked_user), blocked_user, class: "small fw-semibold text-purple text-decoration-none" %>
                </div>
                <%= button_to "Unblock", user_block_path(blocked_user), method: :delete, class: "btn btn-sm btn-outline-secondary flex-shrink-0" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted small text-center mb-0">You haven't blocked anyone.</p>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
