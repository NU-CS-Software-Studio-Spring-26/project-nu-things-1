<% content_for :title, "#{@conversation.subject} — Messages" %>

<div class="mb-3">
  <%= link_to "← Back to messages", conversations_path, class: "link-primary small" %>
</div>

<div class="card nu-card mb-4">
  <div class="card-body">
    <h1 class="h4 text-purple mb-1"><%= @conversation.subject %></h1>
    <% listable = @conversation.listable %>
    <p class="text-muted small mb-2">
      <%= conversation_listable_type_label(listable) %>
      <% if listable %>
        · <%= link_to "View listing", conversation_listable_path(listable), class: "link-primary" %>
      <% end %>
    </p>
    <% other = @conversation.other_participant(current_user) %>
    <% if other %>
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div class="d-flex align-items-center gap-2">
          <%= render "application/user_profile_avatar", user: other, size: :sm %>
          <p class="small mb-0">Conversation with <strong><%= conversation_participant_name(other) %></strong></p>
        </div>
        <% if current_user.blocking?(other) %>
          <%= button_to "Unblock user", user_block_path(other), method: :delete, class: "btn btn-sm btn-outline-secondary" %>
        <% else %>
          <%= button_to "Block user", user_block_path(other), method: :post,
                        class: "btn btn-sm btn-outline-danger",
                        form: { data: { turbo_confirm: "Block this user? They won't be able to send new messages or see your listings." } } %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="card nu-card mb-4">
  <div class="card-body d-flex flex-column gap-3" role="log" aria-live="polite" aria-relevant="additions">
    <% @messages.each do |message| %>
      <% mine = message.sender_id == current_user.id %>
      <div class="nu-message-row d-flex gap-2 align-items-start <%= mine ? 'nu-message-row--mine flex-row-reverse' : 'nu-message-row--theirs' %>">
        <div class="nu-message-row__avatar flex-shrink-0">
          <%= render "application/user_profile_avatar", user: message.sender, size: :sm %>
        </div>
        <div class="nu-message-bubble <%= mine ? 'nu-message-bubble--mine' : 'nu-message-bubble--theirs' %> rounded-3 px-3 py-2">
          <p class="small fw-semibold mb-1 <%= mine ? 'text-white-50' : 'text-muted' %>">
            <%= conversation_participant_name(message.sender) %>
          </p>
          <p class="mb-1 <%= mine ? 'text-white' : '' %>" style="white-space: pre-wrap;"><%= message.body %></p>
          <time class="small <%= mine ? 'text-white-50' : 'text-muted' %>" datetime="<%= message.created_at.iso8601 %>">
            <%= message.created_at.strftime("%-l:%M %p") %>
          </time>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% if @marketplace_transaction.present? %>
  <%= render "conversations/marketplace_transaction", transaction: @marketplace_transaction %>
<% end %>

<% other = @conversation.other_participant(current_user) %>
<div class="card nu-card">
  <div class="card-body">
    <h2 class="h6 text-purple mb-3">Reply</h2>
    <% if conversation_messaging_blocked?(@conversation) %>
      <% if other.present? && current_user.blocking?(other) %>
        <p class="text-muted small mb-0">You blocked this user. Unblock them to send messages again.</p>
      <% else %>
        <p class="text-muted small mb-0">You can no longer send messages in this conversation.</p>
      <% end %>
    <% else %>
    <%= form_with model: @new_message,
                  url: conversation_messages_path(@conversation),
                  local: true,
                  class: "needs-validation" do |f| %>
      <div class="mb-3">
        <%= f.label :body, "Your message", class: "form-label" %>
        <%= f.text_area :body,
                        class: "form-control #{'is-invalid' if @new_message.errors[:body].any?}",
                        required: true,
                        rows: 4,
                        maxlength: ConversationMessage::BODY_MAX_LENGTH,
                        placeholder: "Type your reply..." %>
        <% @new_message.errors.full_messages_for(:body).each do |error| %>
          <div class="invalid-feedback d-block"><%= error %></div>
        <% end %>
      </div>
      <%= f.submit "Send reply", class: "btn btn-primary nu-pill-btn" %>
    <% end %>
    <% end %>
  </div>
</div>
