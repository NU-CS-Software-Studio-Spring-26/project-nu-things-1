<% content_for :title, "Messages — Northwestern Lost and Found Board" %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1 text-purple">Messages</h1>
    <p class="nu-section-lead mb-0">On-site conversations about listings you posted or contacted.</p>
  </div>
</div>

<% if @conversations.any? %>
  <div class="list-group nu-card">
    <% @conversations.each do |conversation| %>
      <% listable = conversation.listable %>
      <% other = conversation.other_participant(current_user) %>
      <%= link_to conversation_path(conversation),
                  class: "list-group-item list-group-item-action d-flex flex-column flex-sm-row justify-content-between align-items-start gap-2 py-3" do %>
        <div class="flex-grow-1 min-w-0">
          <div class="d-flex align-items-center gap-2 mb-1">
            <% if conversation.unread_for?(current_user) %>
              <span class="badge rounded-pill bg-primary">New</span>
            <% end %>
            <h2 class="h6 mb-0 text-purple text-truncate"><%= conversation.subject %></h2>
          </div>
          <p class="small text-muted mb-1">
            <%= conversation_listable_type_label(listable) %>
            <% if other %>
              · with <%= conversation_participant_name(other) %>
            <% end %>
          </p>
          <p class="mb-0 small text-truncate"><%= conversation_preview_text(conversation, current_user) %></p>
        </div>
        <time class="small text-muted flex-shrink-0" datetime="<%= conversation.last_message_at.iso8601 %>">
          <%= time_ago_in_words(conversation.last_message_at) %> ago
        </time>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="card nu-card">
    <div class="card-body text-center py-5">
      <h2 class="h5 text-purple mb-2">No messages yet</h2>
      <p class="text-muted mb-4">When you message someone about a listing, or someone messages you, the thread will appear here.</p>
      <%= link_to "Browse lost items", lost_items_path, class: "btn btn-primary nu-pill-btn" %>
    </div>
  </div>
<% end %>
