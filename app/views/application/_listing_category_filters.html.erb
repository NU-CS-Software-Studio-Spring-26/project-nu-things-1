<%# locals: (categories:, all_categories_path:, category_path:) %>
<div class="d-flex flex-wrap gap-2">
  <%= link_to "All categories", all_categories_path, class: "btn btn-sm #{params[:category].blank? ? 'btn-primary' : 'btn-outline-primary'}", data: { turbo_frame: "listings" } %>
  <% categories.each do |category| %>
    <% if category == "Other" %>
      <%= link_to category, category_path.call(category), class: "btn btn-sm btn-outline-primary nu-filter-other#{' nu-filter-other--selected' if params[:category] == 'Other'}", data: { turbo_frame: "listings" } %>
    <% else %>
      <%= link_to category, category_path.call(category), class: "btn btn-sm #{params[:category] == category ? 'btn-primary' : 'btn-outline-primary'}", data: { turbo_frame: "listings" } %>
    <% end %>
  <% end %>
</div>
