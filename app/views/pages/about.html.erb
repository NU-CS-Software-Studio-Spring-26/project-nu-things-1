<% content_for :title, page_title("About") %>

<div class="card nu-card border-0 shadow-sm">
  <div class="card-body nu-prose mx-auto py-4 px-3 px-md-4" style="max-width: 48rem;">
    <h1 class="h3 text-purple mb-3">About <%= brand_name %></h1>
    <p class="mb-3">
      <%= brand_name %> is a community board for Northwestern students and staff to post <strong>lost</strong> and <strong>found</strong> items,
      browse <strong>rentals</strong>, and use a simple <strong>marketplace</strong>. It is a student project meant to help people on campus connect over belongings and gear.
    </p>
    <p class="mb-3 text-muted">
      This site is <strong>not</strong> affiliated with or endorsed by Northwestern University.
    </p>
    <h2 class="h6 text-uppercase text-muted mb-2">Team</h2>
    <ul class="mb-0">
      <li>Rimen Jenhani</li>
      <li>Shayan Shabani</li>
      <li>Abem Girmai</li>
      <li>Gwendolyn Slaughter</li>
      <li>Nasser Issa</li>
    </ul>
  </div>
</div>
