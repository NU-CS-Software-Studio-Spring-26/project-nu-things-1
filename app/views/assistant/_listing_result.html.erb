<%= link_to listing["path"], class: "card nu-card text-decoration-none #{mine ? 'border-light' : ''}" do %>
  <div class="card-body py-2 px-3">
    <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
      <span class="fw-semibold <%= mine ? 'text-white' : 'text-purple' %>"><%= listing["title"] %></span>
      <span class="badge text-bg-light border flex-shrink-0"><%= listing["board_label"] %></span>
    </div>
    <% if listing["reason"].present? %>
      <p class="small mb-1 <%= mine ? 'text-white-50' : 'text-muted' %>"><%= listing["reason"] %></p>
    <% end %>
    <p class="small mb-0 <%= mine ? 'text-white-50' : 'text-muted' %>">
      <% if listing["category"].present? %>
        <%= listing["category"] %>
        <% if listing["location"].present? %> · <% end %>
      <% end %>
      <% if listing["location"].present? %>
        <%= listing["location"] %>
      <% end %>
    </p>
  </div>
<% end %>
