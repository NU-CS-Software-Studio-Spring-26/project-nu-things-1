<% content_for :title, page_title("AI Finder") %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h2 class="h2 mb-1 text-purple">AI Finder</h2>
    <p class="nu-section-lead mb-0">
      Describe what you're looking for — lost items, found items, rentals, or marketplace listings.
    </p>
  </div>
  <% if @messages.any? %>
    <%= button_to "Clear chat", clear_assistant_path, method: :delete, class: "btn btn-outline-secondary btn-sm nu-pill-btn" %>
  <% end %>
</div>

<% unless @gemini_configured %>
  <div class="alert alert-warning nu-soft-alert" role="alert">
    The AI assistant needs a <code>GEMINI_API_KEY</code> environment variable. See the README for setup.
  </div>
<% end %>

<div class="card nu-card mb-4">
  <div class="card-body d-flex flex-column gap-3 nu-assistant-log" style="max-height: 28rem; overflow-y: auto;" role="log" aria-live="polite" aria-relevant="additions" data-controller="assistant-chat">
    <% if @messages.empty? %>
      <div class="text-muted nu-prose">
        <p class="mb-2"><strong>Try asking:</strong></p>
        <ul class="mb-0">
          <li>I lost a black backpack near SPAC</li>
          <li>Need to rent a tent for camping</li>
          <li>Cheap econ textbook for sale</li>
        </ul>
      </div>
    <% else %>
      <% @messages.each do |message| %>
        <%= render "assistant/message", message: message %>
      <% end %>
    <% end %>
  </div>
</div>

<div class="card nu-card">
  <div class="card-body">
    <h2 class="h6 text-purple mb-3">Ask the assistant</h2>
    <%= form_with url: assistant_messages_path, method: :post, local: true, class: "needs-validation" do %>
      <div class="mb-3">
        <label for="assistant-message" class="form-label">Your message</label>
        <textarea name="message"
                  id="assistant-message"
                  class="form-control"
                  rows="3"
                  required
                  maxlength="1000"
                  placeholder="e.g., I lost my AirPods case at Main Library yesterday"
                  <%= "disabled" unless @gemini_configured %>></textarea>
        <small class="text-muted">Results are suggestions only — always verify listings before contacting someone.</small>
      </div>
      <%= submit_tag "Search", class: "btn btn-primary nu-pill-btn", disabled: !@gemini_configured %>
    <% end %>
  </div>
</div>
