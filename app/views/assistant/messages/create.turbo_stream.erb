<% if @assistant_error.present? %>
  <%= turbo_stream.update "assistant-form-errors" do %>
    <div class="alert alert-warning py-2 px-3 small mb-2" role="alert"><%= @assistant_error %></div>
  <% end %>
<% else %>
  <%= turbo_stream.remove "assistant-empty-state" %>

  <%= turbo_stream.append "assistant-messages" do %>
    <%= render "assistant/message", message: @user_message, widget: true %>
  <% end %>

  <%= turbo_stream.append "assistant-messages" do %>
    <%= render "assistant/message", message: @bot_message, widget: true %>
  <% end %>

  <%= turbo_stream.update "assistant-form-errors" do %><% end %>
<% end %>
