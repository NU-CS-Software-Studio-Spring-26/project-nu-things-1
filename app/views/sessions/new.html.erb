<% content_for :title, "Sign in — Northwestern Lost and Found Board" %>

<div class="row justify-content-center">
  <div class="col-md-7 col-lg-6">
    <div class="card nu-card">
      <div class="card-body">
        <h1 class="h4 text-purple mb-2">Sign in</h1>
        <p class="text-muted mb-4">
          Use your <strong>@u.northwestern.edu</strong> or <strong>@northwestern.edu</strong> email and password.
          Need an account? <%= link_to "Sign up", new_registration_path, class: "nu-link-purple" %>.
        </p>

        <%= form_with url: session_path, method: :post do |f| %>
          <div class="mb-3">
            <%= label_tag :email, "Email", class: "form-label" %>
            <%= email_field_tag :email, params[:email], class: "form-control", required: true, autocomplete: "username", placeholder: "you@u.northwestern.edu" %>
          </div>

          <div class="mb-3">
            <%= label_tag :password, "Password", class: "form-label" %>
            <%= password_field_tag :password, nil, class: "form-control", required: true, autocomplete: "current-password" %>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Sign in", class: "btn btn-primary nu-pill-btn" %>
            <%= link_to "Cancel", root_path, class: "btn btn-outline-secondary nu-pill-btn" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
