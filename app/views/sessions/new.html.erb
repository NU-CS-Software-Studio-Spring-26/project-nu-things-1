<% content_for :title, page_title("Sign in") %>

<div class="row justify-content-center">
  <div class="col-md-7 col-lg-6">
    <div class="card nu-card">
      <div class="card-body">
        <h2 class="h4 text-purple mb-2">Sign in</h2>
        <p class="text-muted mb-4">
          Use your <strong>@u.northwestern.edu</strong> or <strong>@northwestern.edu</strong> Google account.
          First-time visitors are registered automatically when they sign in.
        </p>

        <% if @return_to.present? %>
          <p class="small text-muted mb-3">After signing in, you’ll return to finish what you started.</p>
        <% end %>

        <%= button_to "/auth/google_oauth2",
                      method: :post,
                      class: "btn btn-primary nu-pill-btn w-100 mb-3",
                      form: { data: { turbo: false } } do %>
          Continue with Google
        <% end %>

        <% if Rails.env.development? && @dev_sign_in_users.present? %>
          <div class="border-top pt-3 mt-2">
            <p class="small fw-semibold text-purple mb-2">Local dev sign-in (no Google Cloud)</p>
            <p class="small text-muted mb-3">
              Use local accounts without Google popups. Includes two admin accounts so you can switch roles quickly.
            </p>
            <% @dev_sign_in_users.each do |user| %>
              <%= button_to "Sign in as #{user.first_name} (#{user.email})",
                            dev_sign_in_session_path(user_id: user.id),
                            method: :post,
                            class: "btn btn-outline-primary btn-sm w-100 mb-2" %>
            <% end %>
          </div>
        <% end %>

        <div class="d-flex flex-wrap gap-2 mt-3">
          <%= link_to "Cancel", root_path, class: "btn btn-outline-secondary nu-pill-btn" %>
        </div>
      </div>
    </div>
  </div>
</div>
