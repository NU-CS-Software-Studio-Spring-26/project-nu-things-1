<% content_for :title, page_title("Sign in") %>

<div class="row justify-content-center">
  <div class="col-md-7 col-lg-6">
    <div class="card nu-card">
      <div class="card-body">
        <h1 class="h4 text-purple mb-2">Sign in</h1>
        <p class="text-muted mb-4">
          Use your <strong>@u.northwestern.edu</strong> or <strong>@northwestern.edu</strong> Google account.
          First-time visitors are registered automatically when they sign in.
        </p>

        <% if @return_to.present? %>
          <p class="small text-muted mb-3">After signing in, you’ll return to finish what you started.</p>
        <% end %>

        <%= button_to "/auth/google_oauth2",
                      method: :post,
                      class: "btn btn-primary nu-pill-btn w-100 mb-3",
                      form: { data: { turbo: false } } do %>
          Continue with Google
        <% end %>

        <div class="d-flex flex-wrap gap-2">
          <%= link_to "Cancel", root_path, class: "btn btn-outline-secondary nu-pill-btn" %>
        </div>
      </div>
    </div>
  </div>
</div>
