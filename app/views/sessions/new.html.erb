<% content_for :title, "Sign in — Northwestern Lost and Found Board" %>

<div class="row justify-content-center">
  <div class="col-md-7 col-lg-6">
    <div class="card nu-card">
      <div class="card-body">
        <h1 class="h4 text-purple mb-2">Sign in</h1>
        <p class="text-muted mb-4">
          Enter your <strong>@northwestern.edu</strong> email and we’ll send you a one-time sign-in link.
        </p>

        <%= form_with url: session_path, method: :post do |f| %>
          <div class="mb-3">
            <%= label_tag :email, "Email", class: "form-label" %>
            <%= email_field_tag :email, nil, class: "form-control", required: true, placeholder: "you@northwestern.edu" %>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Email me a link", class: "btn btn-primary" %>
            <%= link_to "Cancel", root_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

