<% content_for :title, page_title("Rental Marketplace") %>

<div class="nu-rental-market">
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h2 class="h2 mb-1 text-purple">Rental Marketplace</h2>
    <p class="text-muted mb-0">Browse items available for rent or post something you'd like to share.</p>
  </div>
  <%= link_to_new_listing "Post item for rent", new_rental_item_path, class: "btn btn-primary" %>
</div>

<%= turbo_frame_tag "listings", data: { controller: "listing-search" } do %>
  <%= render "application/listing_search_bar", url: rental_items_path, preserve_params: { category: params[:category] }, input_id: "rental-items-search-q" %>

  <div class="card nu-card mb-4">
    <div class="card-body">
      <h6 class="card-title text-purple mb-3">Filter by category</h6>
      <%= render "application/listing_category_filters",
                 categories: @categories,
                 all_categories_path: rental_items_path(q: params[:q]),
                 category_path: ->(category) { rental_items_path(category: category, q: params[:q]) } %>
    </div>
  </div>

  <%= render "application/listing_search_results_summary", total_count: listing_index_total_count(@pagy, @grouped_rental_items) %>

  <% if listing_index_grouped_by_category? && @grouped_rental_items.present? %>
    <%= render "application/listing_index_grouped_sections", grouped_items: @grouped_rental_items, item_partial: "rental_items/listing_card" %>
  <% elsif @rental_items.any? %>
    <div class="row g-4">
      <% @rental_items.each do |listing| %>
        <%= render "rental_items/listing_card", item: listing %>
      <% end %>
    </div>
    <%= render "application/listing_pagination", pagy: @pagy %>
  <% elsif listing_index_filters_active? %>
    <div class="alert alert-info">
      No results match your search.
      <%= link_to "Clear filters", rental_items_path, class: "alert-link", data: { turbo_frame: "listings", action: "listing-search#clearFilters" } %>
    </div>
  <% else %>
    <div class="alert alert-info">No rental items available. Be the first to <%= link_to_new_listing "post an item", new_rental_item_path, class: "alert-link" %>.</div>
  <% end %>
<% end %>
</div>
