<% content_for :title, "Rental Marketplace — Northwestern Lost and Found Board" %>

<div class="nu-rental-market">
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1 text-purple">Rental Marketplace</h1>
    <p class="text-muted mb-0">Browse items available for rent or post something you'd like to share.</p>
  </div>
  <%= link_to_new_listing "Post item for rent", new_rental_item_path, class: "btn btn-primary" %>
</div>

<div class="card nu-card mb-4">
  <div class="card-body">
    <h6 class="card-title text-purple mb-3">Filter by category</h6>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "All categories", rental_items_path, class: "btn btn-sm #{params[:category].blank? ? 'btn-primary' : 'btn-outline-primary'}" %>
      <% @categories.each do |category| %>
        <% if category == "Other" %>
          <%= link_to category, rental_items_path(category: category), class: "btn btn-sm btn-outline-primary nu-filter-other#{' nu-filter-other--selected' if params[:category] == 'Other'}" %>
        <% else %>
          <%= link_to category, rental_items_path(category: category), class: "btn btn-sm #{params[:category] == category ? 'btn-primary' : 'btn-outline-primary'}" %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<% if @rental_items.any? %>
  <div class="row g-4">
    <% @rental_items.each do |item| %>
      <div class="col-md-6 col-lg-4">
        <div class="card nu-card h-100">
          <% if item.listing_image_available? %>
            <%= listing_image_tag item, alt: item.title, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
          <% else %>
            <%= render "application/listing_image_placeholder", height: "200px", extra_classes: "card-img-top" %>
          <% end %>
          <div class="card-body">
            <h5 class="card-title"><%= link_to item.title, item, class: "text-decoration-none" %></h5>
            <p class="card-text text-muted small mb-2"><%= truncate(item.description, length: 80) %></p>

            <div class="mb-2">
              <span class="badge text-bg-primary"><%= item.category %></span>
              <span class="badge text-bg-light border"><%= item.condition %></span>
            </div>

            <div class="mb-3">
              <p class="h5 text-primary mb-1"><%= number_with_precision(item.rental_price, precision: 2) %><span class="text-muted fs-6">/<%= item.rental_period.gsub("per_", "") %></span></p>
              <p class="text-muted small mb-0"><%= item.location %></p>
            </div>

            <div class="d-grid gap-2">
              <%= link_to "View details", item, class: "btn btn-sm btn-primary" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info">No rental items available. Be the first to <%= link_to_new_listing "post an item", new_rental_item_path, class: "alert-link" %>.</div>
<% end %>
</div>
