<% content_for :title, "#{@rental_item.title} — Rental Item" %>

<div class="nu-rental-market">
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-3">
  <div>
    <h1 class="h2 mb-2 text-primary"><%= @rental_item.title %></h1>
    <span class="badge text-bg-primary"><%= @rental_item.category %></span>
    <span class="badge text-bg-light border ms-1"><%= @rental_item.condition %></span>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to "Back to rentals", rental_items_path, class: "btn btn-outline-secondary btn-sm" %>
    <% if can_edit_post?(@rental_item) %>
      <%= link_to "Edit", edit_rental_item_path(@rental_item), class: "btn btn-primary btn-sm" %>
    <% end %>
    <% if admin? %>
      <%= button_to "Delete", @rental_item, method: :delete, class: "btn btn-danger btn-sm", form: { data: { turbo_confirm: "Delete this rental item?" } } %>
    <% end %>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card nu-card mb-4">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase mb-3">Photo</h2>
        <% if @rental_item.listing_image_available? %>
          <%= listing_image_tag @rental_item, alt: @rental_item.title, class: "nu-item-img d-block mx-auto" %>
        <% else %>
          <%= render "application/listing_image_placeholder", height: "300px", extra_classes: "rounded nu-listing-image-placeholder--in-body" %>
        <% end %>
      </div>
    </div>

    <div class="card nu-card">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase">Description</h2>
        <div class="mb-4 nu-prose"><%= simple_format(@rental_item.description) %></div>

        <dl class="row mb-0">
          <dt class="col-sm-4">Location</dt>
          <dd class="col-sm-8"><%= @rental_item.location %></dd>

          <dt class="col-sm-4">Available from</dt>
          <dd class="col-sm-8"><%= @rental_item.available_from&.strftime("%B %d, %Y") %></dd>

          <dt class="col-sm-4">Available until</dt>
          <dd class="col-sm-8"><%= @rental_item.available_to&.strftime("%B %d, %Y") %></dd>

          <% if @rental_item.deposit_required.present? && @rental_item.deposit_required > 0 %>
            <dt class="col-sm-4">Suggested deposit</dt>
            <dd class="col-sm-8">$<%= number_with_precision(@rental_item.deposit_required, precision: 2) %></dd>
          <% end %>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card nu-card mb-3">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase mb-3">Price</h2>
        <p class="h3 text-primary mb-2"><%= format_rental_rate(@rental_item) %></p>
        <%= render "rental_stats", item: @rental_item %>
      </div>
    </div>

    <div class="card nu-card mb-3">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase mb-3">Request booking</h2>
        <% if signed_in? %>
          <%= form_with model: [ @rental_item, Booking.new ], local: true, class: "needs-validation" do |f| %>
            <div class="mb-3">
              <%= f.label :start_date, "Start date", class: "form-label" %>
              <%= f.date_field :start_date, class: "form-control", required: true, min: @rental_item.available_from, max: @rental_item.available_to %>
            </div>

            <div class="mb-3">
              <%= f.label :end_date, "End date", class: "form-label" %>
              <%= f.date_field :end_date, class: "form-control", required: true, min: @rental_item.available_from, max: @rental_item.available_to %>
            </div>

            <div class="mb-3">
              <%= f.label :notes, "Additional notes (optional)", class: "form-label" %>
              <%= f.text_area :notes, class: "form-control", rows: 3, placeholder: "Ask about specific dates, ask any questions, etc." %>
            </div>

            <%= f.submit "Request booking", class: "btn btn-primary w-100" %>
          <% end %>
        <% else %>
          <p class="text-muted small mb-3">Sign in with your Northwestern Google account to request dates.</p>
          <%= link_to "Sign in", new_session_path, class: "btn btn-primary w-100" %>
        <% end %>
      </div>
    </div>

    <% if signed_in? && @my_bookings_on_item.present? %>
      <div class="card nu-card mb-3">
        <div class="card-body">
          <h2 class="h6 text-muted text-uppercase mb-3">Your booking requests</h2>
          <ul class="list-group list-group-flush">
            <% @my_bookings_on_item.each do |b| %>
              <li class="list-group-item px-0 d-flex flex-column gap-2">
                <div>
                  <span class="fw-semibold"><%= b.start_date.strftime("%b %-d") %> – <%= b.end_date.strftime("%b %-d, %Y") %></span>
                  <span class="badge text-bg-light border ms-2"><%= b.status.titleize %></span>
                </div>
                <% if b.renter_can_leave_review? && b.renter_review.blank? && b.rental_item.user_id.present? %>
                  <%= link_to "Rate this rental", new_rental_item_booking_review_path(@rental_item, b), class: "btn btn-sm btn-outline-primary nu-pill-btn align-self-start" %>
                <% elsif b.renter_review.present? %>
                  <span class="small text-muted">You rated this rental (<%= b.renter_review.rating %>/5).</span>
                <% elsif b.status != "cancelled" && b.end_date >= Date.current %>
                  <span class="small text-muted">You can leave a review after the rental end date.</span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <% if signed_in? %>
      <div class="card nu-card mb-3">
        <div class="card-body">
          <h2 class="h6 text-muted text-uppercase">Contact Owner</h2>
          <p class="mb-1"><strong><%= @rental_item.owner_name %></strong></p>
          <p class="mb-2"><%= mail_to @rental_item.owner_email, @rental_item.owner_email, class: "link-primary" %></p>
          <% if @rental_item.owner_phone.present? %>
            <p class="mb-3"><%= @rental_item.owner_phone %></p>
          <% end %>
          <button class="btn btn-outline-primary w-100" data-bs-toggle="modal" data-bs-target="#contactModal">Send a message</button>
        </div>
      </div>
    <% else %>
      <div class="card nu-card mb-3">
        <div class="card-body">
          <h2 class="h6 text-muted text-uppercase">Contact Owner</h2>
          <p class="text-muted small mb-3">Sign in with your Northwestern email to view owner contact details and send a message.</p>
          <%= link_to "Sign in", new_session_path, class: "btn btn-outline-primary w-100" %>
        </div>
      </div>
    <% end %>

    <div class="card nu-card">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase mb-2">Payment</h2>
        <p class="text-muted small mb-0">Contact the owner to arrange payment via Venmo or Zelle. Discuss deposit and rental terms directly.</p>
      </div>
    </div>
  </div>
</div>

<% if signed_in? %>
  <!-- Contact Modal -->
  <div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5 text-primary" id="contactModalLabel">Inquire about "<%= @rental_item.title %>"</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <%= form_with url: create_rental_item_contact_path, method: :post, local: true, class: "needs-validation" do |f| %>
          <div class="modal-body">
            <%= hidden_field_tag :rental_item_id, @rental_item.id %>

            <div class="mb-3">
              <%= f.label :sender_name, "Your name", class: "form-label" %>
              <%= f.text_field :sender_name, value: prefilled_sender_name_field, class: "form-control", required: true, placeholder: "Enter your name" %>
            </div>

            <div class="mb-3">
              <%= f.label :sender_email, "Your email", class: "form-label" %>
              <%= f.email_field :sender_email, value: prefilled_sender_email_field, class: "form-control", required: true, placeholder: "Enter your email" %>
            </div>

            <div class="mb-3">
              <%= f.label :message, "Message", class: "form-label" %>
              <%= f.text_area :message, class: "form-control", required: true, placeholder: "Ask about rental dates, price, deposit, etc.", rows: 5 %>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <%= f.submit "Send message", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
</div>
