<% content_for :title, "Sign up — Northwestern Lost and Found Board" %>

<div class="row justify-content-center">
  <div class="col-md-7 col-lg-6">
    <div class="card nu-card">
      <div class="card-body">
        <h1 class="h4 text-purple mb-2">Create account</h1>
        <p class="text-muted mb-4">
          Only <strong>@u.northwestern.edu</strong> and <strong>@northwestern.edu</strong> emails are allowed.
          Already registered? <%= link_to "Sign in", new_session_path, class: "link-primary" %>.
        </p>

        <%= form_with model: @user, url: registration_path do |f| %>
          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <ul class="mb-0 ps-3">
                <% @user.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :email, "Northwestern email", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true, autocomplete: "username", placeholder: "you@u.northwestern.edu" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, "Password", class: "form-label" %>
            <%= f.password_field :password, class: "form-control", required: true, autocomplete: "new-password", minlength: 8 %>
            <div class="form-text">At least 8 characters.</div>
          </div>

          <div class="mb-3">
            <%= f.label :password_confirmation, "Confirm password", class: "form-label" %>
            <%= f.password_field :password_confirmation, class: "form-control", required: true, autocomplete: "new-password" %>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <%= f.submit "Create account", class: "btn btn-primary nu-pill-btn" %>
            <%= link_to "Cancel", root_path, class: "btn btn-outline-secondary nu-pill-btn" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
