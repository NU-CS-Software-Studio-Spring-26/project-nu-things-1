<% content_for :title, "Home — NU Things" %>

<div class="nu-hero p-4 p-md-5 mb-4">
  <%= render "application/home_hero_paper" %>
  <div class="nu-hero__inner">
  <div class="row align-items-center g-4">
    <div class="col-lg-7">
      <h1 class="display-6 fw-bold text-purple mb-3">NU Things</h1>
      <p class="lead nu-section-lead mb-0 nu-prose">
        You need a Northwestern account to post a listing or claim a found item.
        <%= link_to "Sign in", new_session_path, class: "nu-link-purple" %>, or
        <%= link_to "create an account", new_registration_path, class: "nu-link-purple" %> first.
      </p>
    </div>
    <div class="col-lg-5">
      <div class="card nu-card nu-home-actions">
        <div class="card-body">
          <p class="small fw-semibold text-purple text-uppercase mb-2" style="letter-spacing: 0.04em;">Browse</p>
          <div class="row g-2 mb-2">
            <div class="col-6">
              <%= link_to lost_items_path, class: "nu-browse-card nu-browse-lost text-decoration-none" do %>
                <span class="nu-browse-symbol" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="nu-browse-icon" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="10.5" cy="10.5" r="5.8" stroke="currentColor" stroke-width="2.2"/>
                    <path d="M14.8 14.9L20 20.1" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
                  </svg>
                </span>
                <span class="nu-browse-title">Browse Lost Items</span>
                <span class="nu-browse-subtitle">Post and browse for what you lost on campus</span>
              <% end %>
            </div>
            <div class="col-6">
              <%= link_to found_items_path, class: "nu-browse-card nu-browse-found text-decoration-none" do %>
                <span class="nu-browse-symbol" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="nu-browse-icon" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8.4 7.2c0-2 1.6-3.6 3.6-3.6s3.6 1.6 3.6 3.6v1.2h-1.9V7.2c0-1-0.8-1.8-1.8-1.8S10.1 6.2 10.1 7.2v1.2H8.4V7.2z" fill="currentColor"/>
                    <path d="M7.1 8.7h9.8c2.1 0 3.8 1.7 3.8 3.8v6c0 1.1-0.9 2-2 2H5.3c-1.1 0-2-0.9-2-2v-6c0-2.1 1.7-3.8 3.8-3.8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    <path d="M9.4 13.2h5.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M12 11.8v2.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M7.7 9.6v9.7M16.3 9.6v9.7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity="0.55"/>
                  </svg>
                </span>
                <span class="nu-browse-title">Browse Found Items</span>
                <span class="nu-browse-subtitle">Post and browse for what you found on campus</span>
              <% end %>
            </div>
          </div>
          <div class="row g-2 mb-2">
            <div class="col-6">
              <%= link_to rental_items_path, class: "nu-browse-card nu-browse-found text-decoration-none" do %>
                <span class="nu-browse-symbol" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="nu-browse-icon" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 10h16v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    <path d="M3 10V7a2 2 0 0 1 2-2h2V3h2v2h6V3h2v2h2a2 2 0 0 1 2 2v3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M8 14h8M8 17h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                  </svg>
                </span>
                <span class="nu-browse-title">Need to rent?</span>
                <span class="nu-browse-subtitle">Browse gear and tools—or post something to rent out</span>
              <% end %>
            </div>
            <div class="col-6">
              <%= link_to marketplace_listings_path, class: "nu-browse-card nu-browse-lost text-decoration-none" do %>
                <span class="nu-browse-symbol" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="nu-browse-icon" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 9h15l-1.2 12H7.2L6 9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    <path d="M9 9V7a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="2"/>
                  </svg>
                </span>
                <span class="nu-browse-title">Buy or sell?</span>
                <span class="nu-browse-subtitle">Browse listings for sale or post what you're looking for</span>
              <% end %>
            </div>
          </div>
          <p class="small fw-semibold text-purple text-uppercase mb-2 mt-1" style="letter-spacing: 0.04em;">Post something</p>
          <div class="d-grid gap-2">
            <%= link_to_new_listing "Post lost item", new_lost_item_path, class: "btn nu-pill-btn nu-report-lost" %>
            <%= link_to_new_listing "Post found item", new_found_item_path, class: "btn nu-pill-btn nu-report-found" %>
            <%= link_to_new_listing "Post rental item", new_rental_item_path, class: "btn nu-pill-btn nu-rentals" %>
            <%= link_to_new_listing "Post marketplace listing", new_marketplace_listing_path, class: "btn nu-pill-btn nu-marketplace-post" %>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
</div>
