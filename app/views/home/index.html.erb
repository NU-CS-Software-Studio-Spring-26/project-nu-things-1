<% content_for :title, "Home — Northwestern Lost and Found Board" %>

<div class="nu-hero p-4 p-md-5 mb-4">
  <div class="row align-items-center g-4">
    <div class="col-lg-7">
      <h1 class="display-6 fw-bold text-purple mb-3">Northwestern Lost and Found Board</h1>
    </div>
    <div class="col-lg-5">
      <div class="card nu-card nu-home-actions">
        <div class="card-body">
          <div class="row g-2 mb-2">
            <div class="col-6">
              <%= link_to lost_items_path, class: "nu-browse-card nu-browse-lost text-decoration-none" do %>
                <span class="nu-browse-symbol" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="nu-browse-icon" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="10.5" cy="10.5" r="5.8" stroke="currentColor" stroke-width="2.2"/>
                    <path d="M14.8 14.9L20 20.1" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
                  </svg>
                </span>
                <span class="nu-browse-title">Browse Lost Items</span>
                <span class="nu-browse-subtitle">Post and browse for what you lost on campus</span>
              <% end %>
            </div>
            <div class="col-6">
              <%= link_to found_items_path, class: "nu-browse-card nu-browse-found text-decoration-none" do %>
                <span class="nu-browse-symbol" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="nu-browse-icon" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8.4 7.2c0-2 1.6-3.6 3.6-3.6s3.6 1.6 3.6 3.6v1.2h-1.9V7.2c0-1-0.8-1.8-1.8-1.8S10.1 6.2 10.1 7.2v1.2H8.4V7.2z" fill="currentColor"/>
                    <path d="M7.1 8.7h9.8c2.1 0 3.8 1.7 3.8 3.8v6c0 1.1-0.9 2-2 2H5.3c-1.1 0-2-0.9-2-2v-6c0-2.1 1.7-3.8 3.8-3.8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    <path d="M9.4 13.2h5.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M12 11.8v2.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M7.7 9.6v9.7M16.3 9.6v9.7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity="0.55"/>
                  </svg>
                </span>
                <span class="nu-browse-title">Browse Found Items</span>
                <span class="nu-browse-subtitle">Post and browse for what you found on campus</span>
              <% end %>
            </div>
          </div>
          <div class="d-grid gap-2">
            <%= link_to "Report lost item", new_lost_item_path, class: "btn nu-pill-btn nu-report-lost" %>
            <%= link_to "Report found item", new_found_item_path, class: "btn nu-pill-btn nu-report-found" %>
            <%= link_to "Browse rentals", rental_items_path, class: "btn nu-pill-btn nu-rentals" %>
            <%= link_to "Browse marketplace", marketplace_listings_path, class: "btn nu-pill-btn nu-rentals" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mb-5">
  <div class="col-md-3">
    <div class="card nu-card h-100">
      <div class="card-body">
        <h2 class="h5 card-title text-purple">Lost something?</h2>
        <p class="card-text text-muted">Create a lost-item post with where and when you last had it, plus a way for finders to reach you.</p>
        <%= link_to "Go to Lost Items", lost_items_path, class: "btn btn-sm btn-outline-primary me-2" %>
        <%= link_to "New report", new_lost_item_path, class: "btn btn-sm btn-primary" %>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card nu-card h-100">
      <div class="card-body">
        <h2 class="h5 card-title text-purple">Found something?</h2>
        <p class="card-text text-muted">List what you picked up and where you turned it in (or where you are holding it) so the owner can follow up.</p>
        <%= link_to "Go to Found Items", found_items_path, class: "btn btn-sm btn-outline-primary me-2" %>
        <%= link_to "New report", new_found_item_path, class: "btn btn-sm btn-primary" %>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card nu-card h-100">
      <div class="card-body">
        <h2 class="h5 card-title text-purple">Need to rent?</h2>
        <p class="card-text text-muted">Browse rental items from camping gear to tools or post something you'd like to rent out to earn some cash.</p>
        <%= link_to "Browse rentals", rental_items_path, class: "btn btn-sm btn-outline-primary me-2" %>
        <%= link_to "Post item", new_rental_item_path, class: "btn btn-sm btn-primary" %>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card nu-card h-100">
      <div class="card-body">
        <h2 class="h5 card-title text-purple">Buy or sell?</h2>
        <p class="card-text text-muted">Post items for sale or request things you’re looking for. Contact each other to arrange pickup and payment.</p>
        <%= link_to "Browse marketplace", marketplace_listings_path, class: "btn btn-sm btn-outline-primary me-2" %>
        <%= link_to "Post listing", new_marketplace_listing_path, class: "btn btn-sm btn-primary" %>
      </div>
    </div>
  </div>
</div>

