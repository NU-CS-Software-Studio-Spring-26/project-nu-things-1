<% content_for :title, "#{@found_item.title} — Found Item" %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-3">
  <div>
    <h1 class="h2 mb-2 text-purple"><%= @found_item.title %></h1>
    <span class="badge rounded-pill <%= found_status_badge_class(@found_item.status) %>"><%= @found_item.status.titleize %></span>
    <span class="badge text-bg-light border ms-1"><%= @found_item.category %></span>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to "Back to found items", found_items_path, class: "btn btn-outline-secondary btn-sm" %>
    <%= link_to "Edit", edit_found_item_path(@found_item), class: "btn btn-primary btn-sm" %>
    <%= button_to "Delete", @found_item, method: :delete, class: "btn btn-danger btn-sm", form: { data: { turbo_confirm: "Delete this found item post?" } } %>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card nu-card">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase">Description</h2>
        <p class="mb-4"><%= simple_format(@found_item.description) %></p>

        <dl class="row mb-0">
          <dt class="col-sm-4">Location found</dt>
          <dd class="col-sm-8"><%= @found_item.location_found %></dd>

          <dt class="col-sm-4">Date found</dt>
          <dd class="col-sm-8"><%= @found_item.date_found&.strftime("%B %d, %Y") %></dd>

          <% if @found_item.storage_location.present? %>
            <dt class="col-sm-4">Storage / turn-in</dt>
            <dd class="col-sm-8"><%= @found_item.storage_location %></dd>
          <% end %>

          <% if @found_item.color.present? %>
            <dt class="col-sm-4">Color</dt>
            <dd class="col-sm-8"><%= @found_item.color %></dd>
          <% end %>

          <% if @found_item.brand.present? %>
            <dt class="col-sm-4">Brand</dt>
            <dd class="col-sm-8"><%= @found_item.brand %></dd>
          <% end %>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card nu-card mb-3">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase">Contact</h2>
        <p class="mb-1"><strong><%= @found_item.contact_name %></strong></p>
        <p class="mb-3"><%= mail_to @found_item.contact_email, @found_item.contact_email, class: "link-primary" %></p>
        <button class="btn btn-info text-dark w-100" data-bs-toggle="modal" data-bs-target="#contactModal">Send a message</button>
      </div>
    </div>

    <% if @found_item.image_url.present? %>
      <div class="card nu-card">
        <div class="card-body">
          <h2 class="h6 text-muted text-uppercase mb-3">Photo</h2>
          <%= image_tag @found_item.image_url, alt: @found_item.title, class: "nu-item-img d-block mx-auto" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Contact Modal -->
<div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5 text-purple" id="contactModalLabel">Contact about "<%= @found_item.title %>"</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <%= form_with url: create_found_item_contact_path, method: :post, local: true, class: "needs-validation" do |f| %>
        <div class="modal-body">
          <%= hidden_field_tag :found_item_id, @found_item.id %>
          
          <div class="mb-3">
            <%= f.label :sender_name, "Your name", class: "form-label" %>
            <%= f.text_field :sender_name, class: "form-control", required: true, placeholder: "Enter your name" %>
          </div>

          <div class="mb-3">
            <%= f.label :sender_email, "Your email", class: "form-label" %>
            <%= f.email_field :sender_email, class: "form-control", required: true, placeholder: "Enter your email" %>
          </div>

          <div class="mb-3">
            <%= f.label :message, "Message", class: "form-label" %>
            <%= f.text_area :message, class: "form-control", required: true, placeholder: "Enter your message", rows: 5 %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= f.submit "Send message", class: "btn btn-info text-dark" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
