<% content_for :title, "#{@found_item.title} — Found Item" %>

<div class="mb-3">
  <%= link_to found_items_path, class: "btn btn-outline-secondary" do %>
    <span aria-hidden="true">←</span> Back to found items
  <% end %>
</div>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-3">
  <div>
    <h1 class="h2 mb-2 text-purple"><%= @found_item.title %></h1>
    <span class="badge rounded-pill <%= found_status_badge_class(@found_item.status) %>"><%= @found_item.status.titleize %></span>
    <span class="badge text-bg-light border ms-1"><%= @found_item.category %></span>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to_new_listing "Post found item", new_found_item_path, class: "btn btn-sm nu-pill-btn nu-report-found" %>
    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#reportListingModal">Report a problem</button>
    <% if can_edit_post?(@found_item) %>
      <%= link_to "Edit", edit_found_item_path(@found_item), class: "btn btn-primary btn-sm" %>
    <% end %>
    <% if admin? %>
      <%= button_to "Delete", @found_item, method: :delete, class: "btn btn-danger btn-sm", form: { data: { turbo_confirm: "Delete this found item post?" } } %>
    <% end %>
  </div>
</div>

<div class="row g-4 align-items-lg-start">
  <div class="col-lg-7">
    <div class="card nu-card mb-4">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase mb-3">Photo</h2>
        <% if @found_item.listing_image_available? %>
          <%= listing_image_tag @found_item, alt: @found_item.title, class: "nu-item-img d-block mx-auto" %>
        <% else %>
          <%= render "application/listing_image_placeholder", height: "300px", extra_classes: "rounded nu-listing-image-placeholder--in-body" %>
        <% end %>
      </div>
    </div>

    <div class="card nu-card">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase">Description</h2>
        <p class="mb-4"><%= simple_format(@found_item.description) %></p>

        <dl class="row mb-0">
          <dt class="col-sm-4">Location found</dt>
          <dd class="col-sm-8"><%= @found_item.location_found %></dd>

          <dt class="col-sm-4">Date found</dt>
          <dd class="col-sm-8"><%= @found_item.date_found&.strftime("%B %d, %Y") %></dd>

          <% if @found_item.storage_location.present? %>
            <dt class="col-sm-4">Storage / turn-in</dt>
            <dd class="col-sm-8"><%= @found_item.storage_location %></dd>
          <% end %>

          <% if @found_item.color.present? %>
            <dt class="col-sm-4">Color</dt>
            <dd class="col-sm-8"><%= @found_item.color %></dd>
          <% end %>

          <% if @found_item.brand.present? %>
            <dt class="col-sm-4">Brand</dt>
            <dd class="col-sm-8"><%= @found_item.brand %></dd>
          <% end %>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="nu-listing-show-sidebar">
      <% if @found_item.status == "unclaimed" %>
        <div class="card nu-card mb-3 border-primary border-opacity-25">
          <div class="card-body">
            <h2 class="h6 text-muted text-uppercase">Claim</h2>
            <% if signed_in? %>
              <p class="small text-muted mb-3">If this is your item, claim it so others know it is resolved.</p>
              <%= button_to "Claim this item", claim_found_item_path(@found_item), method: :post, class: "btn btn-primary w-100" %>
            <% else %>
              <p class="small text-muted mb-3">Sign in with your Northwestern account to claim this item.</p>
              <%= link_to "Sign in to claim", new_session_path, class: "btn btn-primary w-100" %>
            <% end %>
          </div>
        </div>
      <% elsif @found_item.claimed_by_user.present? %>
        <div class="card nu-card mb-3">
          <div class="card-body">
            <h2 class="h6 text-muted text-uppercase">Claimed</h2>
            <% if signed_in? %>
              <p class="mb-0 small text-muted">
                Recorded for <strong><%= @found_item.claimed_by_user.email %></strong>.
              </p>
            <% else %>
              <p class="mb-0 small text-muted">
                Sign in with your Northwestern email to see who claimed this item.
              </p>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if signed_in? %>
        <div class="card nu-card mb-0">
          <div class="card-body">
            <h2 class="h6 text-muted text-uppercase">Contact</h2>
            <p class="mb-1"><strong><%= @found_item.contact_name %></strong></p>
            <p class="mb-3"><%= mail_to @found_item.contact_email, @found_item.contact_email, class: "link-primary" %></p>
            <button class="btn btn-info text-dark w-100" type="button" data-bs-toggle="modal" data-bs-target="#contactModal">Send a message</button>
          </div>
        </div>
      <% else %>
        <div class="card nu-card mb-0">
          <div class="card-body">
            <h2 class="h6 text-muted text-uppercase">Contact</h2>
            <p class="text-muted small mb-3">Sign in with your Northwestern email to view contact details and send a message.</p>
            <%= link_to "Sign in", new_session_path, class: "btn btn-info text-dark w-100" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%= render "shared/listing_report_modal", form_url: report_found_item_path(@found_item), listing_title: @found_item.title %>

<% if signed_in? %>
  <!-- Contact Modal -->
  <div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h1 class="modal-title fs-5 text-purple" id="contactModalLabel">Contact about "<%= @found_item.title %>"</h1>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <%= form_with url: create_found_item_contact_path, method: :post, local: true, class: "needs-validation" do |f| %>
          <div class="modal-body">
            <%= hidden_field_tag :found_item_id, @found_item.id %>

            <div class="mb-3">
              <%= f.label :sender_name, "Your name", class: "form-label" %>
              <%= f.text_field :sender_name, value: prefilled_sender_name_field, class: "form-control", required: true, placeholder: "Enter your name" %>
            </div>

            <div class="mb-3">
              <%= f.label :sender_email, "Your email", class: "form-label" %>
              <%= f.email_field :sender_email, value: prefilled_sender_email_field, class: "form-control", required: true, placeholder: "Enter your email" %>
            </div>

            <div class="mb-3">
              <%= f.label :message, "Message", class: "form-label" %>
              <%= f.text_area :message, class: "form-control", required: true, placeholder: "Enter your message", rows: 5 %>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <%= f.submit "Send message", class: "btn btn-info text-dark" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
