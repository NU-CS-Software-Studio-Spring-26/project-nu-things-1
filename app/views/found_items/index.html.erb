<% content_for :title, page_title("Found Items") %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h2 class="h2 mb-1 text-purple">Found items</h2>
    <p class="nu-section-lead mb-0">Items someone turned in or is holding for the owner.</p>
  </div>
  <%= link_to_new_listing "Post found item", new_found_item_path, class: "btn btn-primary nu-pill-btn" %>
</div>

<%= turbo_frame_tag "listings", data: { controller: "listing-search" } do %>
  <%= render "application/listing_search_bar", url: found_items_path, preserve_params: { category: params[:category] }, input_id: "found-items-search-q" %>

  <div class="card nu-card mb-4">
    <div class="card-body">
      <h6 class="card-title text-purple mb-3">Filter by category</h6>
      <%= render "application/listing_category_filters",
                 categories: @categories,
                 all_categories_path: found_items_path(q: params[:q]),
                 category_path: ->(category) { found_items_path(category: category, q: params[:q]) } %>
    </div>
  </div>

  <%= render "application/listing_search_results_summary", total_count: listing_index_total_count(@pagy, @grouped_found_items) %>

  <% if listing_index_grouped_by_category? && @grouped_found_items.present? %>
    <%= render "application/listing_index_grouped_sections", grouped_items: @grouped_found_items, item_partial: "found_items/listing_card" %>
  <% elsif @found_items.any? %>
    <div class="row g-4">
      <% @found_items.each do |listing| %>
        <%= render "found_items/listing_card", item: listing %>
      <% end %>
    </div>
    <%= render "application/listing_pagination", pagy: @pagy %>
  <% elsif listing_index_filters_active? %>
    <div class="alert nu-soft-alert">
      No results match your search.
      <%= link_to "Clear filters", found_items_path, class: "alert-link", data: { turbo_frame: "listings", action: "listing-search#clearFilters" } %>
    </div>
  <% else %>
    <div class="alert nu-soft-alert">No found items yet. <%= link_to_new_listing "Add the first listing", new_found_item_path, class: "alert-link" %>.</div>
  <% end %>
<% end %>
