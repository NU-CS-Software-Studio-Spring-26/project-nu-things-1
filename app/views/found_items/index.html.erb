<% content_for :title, "Found Items — Northwestern Lost and Found Board" %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1 text-purple">Found items</h1>
    <p class="nu-section-lead mb-0">Items someone turned in or is holding for the owner.</p>
  </div>
  <%= link_to "Report found item", new_found_item_path, class: "btn btn-info text-dark nu-pill-btn" %>
</div>

<div class="card nu-card mb-4">
  <div class="card-body">
    <h6 class="card-title text-purple mb-3">Filter by category</h6>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "All categories", found_items_path, class: "btn btn-sm #{params[:category].blank? ? 'btn-info text-dark' : 'btn-outline-info text-dark'}" %>
      <% @categories.each do |category| %>
        <%= link_to category, found_items_path(category: category), class: "btn btn-sm #{params[:category] == category ? 'btn-info text-dark' : 'btn-outline-info text-dark'}" %>
      <% end %>
    </div>
  </div>
</div>

<% if @found_items.any? %>
  <div class="nu-list-grid">
    <% @found_items.each do |item| %>
      <article class="card nu-card nu-item-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
            <%= link_to item.title, item, class: "fw-semibold nu-item-title" %>
            <span class="badge rounded-pill <%= found_status_badge_class(item.status) %>"><%= item.status.titleize %></span>
          </div>
          <p class="nu-metadata mb-0">
            <strong>Category:</strong> <%= item.category %> ·
            <strong>Found at:</strong> <%= item.location_found %> ·
            <strong>Date:</strong> <%= item.date_found&.strftime("%b %d, %Y") %>
          </p>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <div class="alert nu-soft-alert">No found items yet. <%= link_to "Add the first listing", new_found_item_path, class: "alert-link" %>.</div>
<% end %>
