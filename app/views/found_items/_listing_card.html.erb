<div class="col-md-6 col-lg-4">
  <%= link_to item, class: "card nu-card nu-clickable-card h-100", data: { turbo_frame: "_top" } do %>
    <% if item.listing_image_available? %>
      <%= listing_image_tag item, alt: item.title, class: "card-img-top nu-listing-index-card-img" %>
    <% else %>
      <%= render "application/listing_image_placeholder", aspect_index_card: true, extra_classes: "card-img-top" %>
    <% end %>
    <div class="card-body d-flex flex-column">
      <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
        <h3 class="h5 card-title mb-0 nu-item-title"><%= item.title %></h3>
        <span class="badge rounded-pill flex-shrink-0 <%= found_status_badge_class(item.status) %>"><%= item.status.titleize %></span>
      </div>
      <p class="card-text text-muted small mb-3 flex-grow-1">
        <%= truncate(item.description, length: 100) %>
      </p>
      <div class="mb-2">
        <%= render "application/listing_category_badge", item: item %>
      </div>
      <div class="nu-metadata small mb-3">
        <span class="nu-metadata__item"><strong>Found at:</strong> <%= item.location_found %></span>
        <span class="nu-metadata__item"><strong>Date:</strong> <%= item.date_found&.strftime("%b %d, %Y") %></span>
      </div>
      <div class="d-grid mt-auto">
        <span class="btn btn-sm btn-primary nu-card-cta">View details</span>
      </div>
    </div>
  <% end %>
</div>
