<%= form_with model: found_item do |f| %>
  <%= render "shared/errors", object: found_item %>

  <div class="row g-3">
    <div class="col-md-8">
      <%= f.label :title, "Title *", class: "form-label" %>
      <%= f.text_field :title, class: "form-control", required: true, placeholder: "e.g., Silver Hydro Flask" %>
    </div>
    <div class="col-md-4">
      <%= f.label :category, "Category *", class: "form-label" %>
      <%= f.text_field :category, class: "form-control", required: true %>
    </div>

    <div class="col-12">
      <%= f.label :description, "Description *", class: "form-label" %>
      <%= f.text_area :description, class: "form-control", rows: 4, required: true %>
    </div>

    <div class="col-md-6">
      <%= f.label :location_found, "Location found *", class: "form-label" %>
      <%= f.text_field :location_found, class: "form-control", required: true %>
    </div>
    <div class="col-md-6">
      <%= f.label :date_found, "Date found *", class: "form-label" %>
      <%= f.date_field :date_found, class: "form-control", required: true %>
    </div>

    <div class="col-md-6">
      <%= f.label :contact_name, "Your name *", class: "form-label" %>
      <%= f.text_field :contact_name, class: "form-control", required: true %>
    </div>
    <div class="col-md-6">
      <%= f.label :contact_email, "Contact email *", class: "form-label" %>
      <%= f.email_field :contact_email, class: "form-control", required: true %>
    </div>

    <div class="col-md-4">
      <%= f.label :status, "Status *", class: "form-label" %>
      <%= f.select :status, FoundItem::STATUSES.map { |s| [s.titleize, s] }, {}, class: "form-select" %>
    </div>
    <div class="col-md-8">
      <%= f.label :image_url, "Image URL (optional)", class: "form-label" %>
      <%= f.text_field :image_url, class: "form-control", placeholder: "https://…" %>
    </div>

    <div class="col-md-6">
      <%= f.label :storage_location, "Storage / turn-in location (optional)", class: "form-label" %>
      <%= f.text_field :storage_location, class: "form-control", placeholder: "Norris desk, dorm front desk…" %>
    </div>
    <div class="col-md-3">
      <%= f.label :color, "Color (optional)", class: "form-label" %>
      <%= f.text_field :color, class: "form-control" %>
    </div>
    <div class="col-md-3">
      <%= f.label :brand, "Brand (optional)", class: "form-label" %>
      <%= f.text_field :brand, class: "form-control" %>
    </div>
  </div>

  <div class="mt-4 d-flex flex-wrap gap-2">
    <%= f.submit found_item.persisted? ? "Update listing" : "Post found item", class: "btn btn-primary" %>
    <%= link_to "Cancel", found_item.persisted? ? found_item_path(found_item) : found_items_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
