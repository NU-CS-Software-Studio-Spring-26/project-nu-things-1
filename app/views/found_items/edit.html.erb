<% content_for :title, "Edit found item — Northwestern Lost and Found Board" %>

<h1 class="h2 mb-3 text-purple">Edit found item</h1>
<p class="text-muted mb-4">Update the listing if the item was claimed or details change.</p>

<%= render "form",
           found_item: @found_item,
           form_url: (@owner_token ? update_found_item_owner_path(token: @owner_token) : nil),
           cancel_url: found_item_path(@found_item) %>

<% if @owner_token %>
  <div class="mt-3">
    <%= button_to "Delete this post",
                  destroy_found_item_owner_path(token: @owner_token),
                  method: :delete,
                  class: "btn btn-outline-danger",
                  form: { data: { turbo_confirm: "Delete this found item post?" } } %>
  </div>
<% end %>
