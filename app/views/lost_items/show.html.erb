<% content_for :title, "#{@lost_item.title} — Lost Item" %>

<div class="mb-3">
  <%= link_to lost_items_path, class: "btn btn-outline-secondary" do %>
    <span aria-hidden="true">←</span> Back to lost items
  <% end %>
</div>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-3">
  <div>
    <h1 class="h2 mb-2 text-purple"><%= @lost_item.title %></h1>
    <span class="badge rounded-pill <%= lost_status_badge_class(@lost_item.status) %>"><%= @lost_item.status.titleize %></span>
    <span class="badge text-bg-light border ms-1"><%= @lost_item.category %></span>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to_new_listing "Post lost item", new_lost_item_path, class: "btn btn-sm nu-pill-btn nu-report-lost" %>
    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#reportListingModal">Report a problem</button>
    <% if admin? %>
      <%= link_to "Edit", edit_lost_item_path(@lost_item), class: "btn btn-primary btn-sm" %>
      <%= button_to "Delete", @lost_item, method: :delete, class: "btn btn-danger btn-sm", form: { data: { turbo_confirm: "Delete this lost item post?" } } %>
    <% end %>
  </div>
</div>

<div class="row g-4 align-items-lg-start">
  <div class="col-lg-7">
    <div class="card nu-card mb-4">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase mb-3">Photo</h2>
        <% if @lost_item.listing_image_available? %>
          <%= listing_image_tag @lost_item, alt: @lost_item.title, class: "nu-item-img d-block mx-auto", style: "max-height: 400px; object-fit: contain;" %>
        <% else %>
          <%= render "application/listing_image_placeholder", height: "300px", extra_classes: "rounded nu-listing-image-placeholder--in-body" %>
        <% end %>
      </div>
    </div>

    <div class="card nu-card">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase">Description</h2>
        <p class="mb-4"><%= simple_format(@lost_item.description) %></p>

        <dl class="row mb-0">
          <dt class="col-sm-4">Location lost</dt>
          <dd class="col-sm-8"><%= @lost_item.location_lost %></dd>

          <dt class="col-sm-4">Date lost</dt>
          <dd class="col-sm-8"><%= @lost_item.date_lost&.strftime("%B %d, %Y") %></dd>

          <% if @lost_item.color.present? %>
            <dt class="col-sm-4">Color</dt>
            <dd class="col-sm-8"><%= @lost_item.color %></dd>
          <% end %>

          <% if @lost_item.brand.present? %>
            <dt class="col-sm-4">Brand</dt>
            <dd class="col-sm-8"><%= @lost_item.brand %></dd>
          <% end %>

          <% if @lost_item.reward.present? %>
            <dt class="col-sm-4">Reward</dt>
            <dd class="col-sm-8"><%= @lost_item.reward %></dd>
          <% end %>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="nu-lost-show-sidebar">
      <div class="card nu-card mb-0">
        <div class="card-body">
          <h2 class="h6 text-muted text-uppercase">Contact</h2>
          <p class="mb-1"><strong><%= @lost_item.contact_name %></strong></p>
          <p class="mb-3"><%= mail_to @lost_item.contact_email, @lost_item.contact_email, class: "link-primary" %></p>
          <button class="btn btn-primary w-100" data-bs-toggle="modal" data-bs-target="#contactModal">Send a message</button>
        </div>
      </div>
    </div>
  </div>
</div>

<%= render "shared/listing_report_modal", form_url: report_lost_item_path(@lost_item), listing_title: @lost_item.title %>

<!-- Contact Modal -->
<div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5 text-purple" id="contactModalLabel">Contact about "<%= @lost_item.title %>"</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <%= form_with url: create_lost_item_contact_path, method: :post, local: true, class: "needs-validation" do |f| %>
        <div class="modal-body">
          <%= hidden_field_tag :lost_item_id, @lost_item.id %>
          
          <div class="mb-3">
            <%= f.label :sender_name, "Your name", class: "form-label" %>
            <%= f.text_field :sender_name, value: prefilled_sender_name_field, class: "form-control", required: true, placeholder: "Enter your name" %>
          </div>

          <div class="mb-3">
            <%= f.label :sender_email, "Your email", class: "form-label" %>
            <%= f.email_field :sender_email, value: prefilled_sender_email_field, class: "form-control", required: true, placeholder: "Enter your email" %>
          </div>

          <div class="mb-3">
            <%= f.label :message, "Message", class: "form-label" %>
            <%= f.text_area :message, class: "form-control", required: true, placeholder: "Enter your message", rows: 5 %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= f.submit "Send message", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
