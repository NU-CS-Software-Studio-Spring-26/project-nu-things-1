<% content_for :title, "Edit lost item — Northwestern Lost and Found Board" %>

<h1 class="h2 mb-3 text-purple">Edit lost item</h1>
<p class="text-muted mb-4">Update your listing if details change or the item is found.</p>

<%= render "form",
           lost_item: @lost_item,
           form_url: (@owner_token ? update_lost_item_owner_path(token: @owner_token) : nil),
           cancel_url: lost_item_path(@lost_item) %>

<% if @owner_token %>
  <div class="mt-3">
    <%= button_to "Delete this post",
                  destroy_lost_item_owner_path(token: @owner_token),
                  method: :delete,
                  class: "btn btn-outline-danger",
                  form: { data: { turbo_confirm: "Delete this lost item post?" } } %>
  </div>
<% end %>
