<% content_for :title, "Lost Items — Northwestern Lost and Found Board" %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1 text-purple">Lost items</h1>
    <p class="nu-section-lead mb-0">Recently reported missing belongings around campus.</p>
  </div>
  <%= link_to "Report lost item", new_lost_item_path, class: "btn btn-warning nu-pill-btn" %>
</div>

<div class="card nu-card mb-4">
  <div class="card-body">
    <h6 class="card-title text-purple mb-3">Filter by category</h6>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "All categories", lost_items_path, class: "btn btn-sm #{params[:category].blank? ? 'btn-primary' : 'btn-outline-primary'}" %>
      <% @categories.each do |category| %>
        <%= link_to category, lost_items_path(category: category), class: "btn btn-sm #{params[:category] == category ? 'btn-primary' : 'btn-outline-primary'}" %>
      <% end %>
    </div>
  </div>
</div>

<% if @lost_items.any? %>
  <div class="nu-list-grid">
    <% @lost_items.each do |item| %>
      <article class="card nu-card nu-item-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
            <%= link_to item.title, item, class: "fw-semibold nu-item-title" %>
            <span class="badge rounded-pill <%= lost_status_badge_class(item.status) %>"><%= item.status.titleize %></span>
          </div>
          <p class="nu-metadata mb-0">
            <strong>Category:</strong> <%= item.category %> ·
            <strong>Lost at:</strong> <%= item.location_lost %> ·
            <strong>Date:</strong> <%= item.date_lost&.strftime("%b %d, %Y") %>
          </p>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <div class="alert nu-soft-alert">No lost items yet. Be the first to <%= link_to "post a report", new_lost_item_path, class: "alert-link" %>.</div>
<% end %>
