<% content_for :title, "Lost Items — Northwestern Lost and Found Board" %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1 text-purple">Lost items</h1>
    <p class="nu-section-lead mb-0">Recently reported missing belongings around campus.</p>
  </div>
  <%= link_to_new_listing "Post lost item", new_lost_item_path, class: "btn btn-primary nu-pill-btn" %>
</div>

<div class="card nu-card mb-4">
  <div class="card-body">
    <h2 class="h6 card-title text-purple mb-3">Filter by category</h2>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "All categories", lost_items_path, class: "btn btn-sm #{params[:category].blank? ? 'btn-primary' : 'btn-outline-primary'}" %>
      <% @categories.each do |category| %>
        <% if category == "Other" %>
          <%= link_to category, lost_items_path(category: category), class: "btn btn-sm btn-outline-primary nu-filter-other#{' nu-filter-other--selected' if params[:category] == 'Other'}" %>
        <% else %>
          <%= link_to category, lost_items_path(category: category), class: "btn btn-sm #{params[:category] == category ? 'btn-primary' : 'btn-outline-primary'}" %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<% if @lost_items.any? %>
  <div class="row g-4">
    <% @lost_items.each do |item| %>
      <div class="col-md-6 col-lg-4">
        <article class="card nu-card h-100" aria-labelledby="<%= dom_id(item, :title) %>">
          <% if item.listing_image_available? %>
            <%= listing_image_tag item, alt: item.title, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
          <% else %>
            <%= render "application/listing_image_placeholder", height: "200px", extra_classes: "card-img-top" %>
          <% end %>
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
              <h3 id="<%= dom_id(item, :title) %>" class="h5 card-title mb-0"><%= link_to item.title, item, class: "nu-item-title text-decoration-none" %></h3>
              <span class="badge rounded-pill flex-shrink-0 <%= lost_status_badge_class(item.status) %>"><%= item.status.titleize %></span>
            </div>
            <p class="card-text text-muted small mb-3 flex-grow-1">
              <%= truncate(item.description, length: 100) %>
            </p>
            <p class="nu-metadata small mb-3">
              <strong>Category:</strong> <%= item.category %> ·
              <strong>Lost at:</strong> <%= item.location_lost %> ·
              <strong>Date:</strong> <%= item.date_lost&.strftime("%b %d, %Y") %>
            </p>
            <div class="d-grid mt-auto">
              <%= link_to "View details", item, class: "btn btn-sm btn-primary" %>
            </div>
          </div>
        </article>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert nu-soft-alert">No lost items yet. Be the first to <%= link_to_new_listing "post a report", new_lost_item_path, class: "alert-link" %>.</div>
<% end %>
