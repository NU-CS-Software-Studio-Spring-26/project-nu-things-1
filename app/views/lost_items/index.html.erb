<% content_for :title, "Lost Items — Northwestern Lost and Found Board" %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1 text-purple">Lost items</h1>
    <p class="text-muted mb-0">Recently reported missing belongings around campus.</p>
  </div>
  <%= link_to "Report lost item", new_lost_item_path, class: "btn btn-warning" %>
</div>

<% if @lost_items.any? %>
  <div class="table-responsive card nu-card">
    <table class="table table-hover align-middle mb-0 nu-table">
      <thead>
        <tr>
          <th scope="col">Title</th>
          <th scope="col">Category</th>
          <th scope="col">Location lost</th>
          <th scope="col">Date lost</th>
          <th scope="col">Status</th>
        </tr>
      </thead>
      <tbody>
        <% @lost_items.each do |item| %>
          <tr>
            <td><%= link_to item.title, item, class: "fw-semibold text-decoration-none" %></td>
            <td><%= item.category %></td>
            <td><%= item.location_lost %></td>
            <td><%= item.date_lost&.strftime("%b %d, %Y") %></td>
            <td><span class="badge rounded-pill <%= lost_status_badge_class(item.status) %>"><%= item.status.titleize %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="alert alert-info">No lost items yet. Be the first to <%= link_to "post a report", new_lost_item_path, class: "alert-link" %>.</div>
<% end %>
