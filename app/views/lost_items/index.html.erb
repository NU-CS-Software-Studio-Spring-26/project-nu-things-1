<% content_for :title, page_title("Lost Items") %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h2 class="h2 mb-1 text-purple">Lost items</h2>
    <p class="nu-section-lead mb-0">Recently reported missing belongings around campus.</p>
  </div>
  <%= link_to_new_listing "Post lost item", new_lost_item_path, class: "btn btn-primary nu-pill-btn" %>
</div>

<%= turbo_frame_tag "listings", data: { controller: "listing-search" } do %>
  <%= render "application/listing_search_bar", url: lost_items_path, preserve_params: { category: params[:category] }, input_id: "lost-items-search-q" %>

  <div class="card nu-card mb-4">
    <div class="card-body">
      <h6 class="card-title text-purple mb-3">Filter by category</h6>
      <%= render "application/listing_category_filters",
                 categories: @categories,
                 all_categories_path: lost_items_path(q: params[:q]),
                 category_path: ->(category) { lost_items_path(category: category, q: params[:q]) } %>
    </div>
  </div>

  <%= render "application/listing_search_results_summary", total_count: listing_index_total_count(@pagy, @grouped_lost_items) %>

  <% if listing_index_grouped_by_category? && @grouped_lost_items.present? %>
    <%= render "application/listing_index_grouped_sections", grouped_items: @grouped_lost_items, item_partial: "lost_items/listing_card" %>
  <% elsif @lost_items.any? %>
    <div class="row g-4">
      <% @lost_items.each do |listing| %>
        <%= render "lost_items/listing_card", item: listing %>
      <% end %>
    </div>
    <%= render "application/listing_pagination", pagy: @pagy %>
  <% elsif listing_index_filters_active? %>
    <div class="alert nu-soft-alert">
      No results match your search.
      <%= link_to "Clear filters", lost_items_path, class: "alert-link", data: { turbo_frame: "listings", action: "listing-search#clearFilters" } %>
    </div>
  <% else %>
    <div class="alert nu-soft-alert">No lost items yet. Be the first to <%= link_to_new_listing "post a report", new_lost_item_path, class: "alert-link" %>.</div>
  <% end %>
<% end %>
