<%= form_with model: lost_item, class: "needs-validation", html: { multipart: true } do |f| %>
  <div class="card nu-card nu-form-card">
    <div class="card-body">
      <%= render "shared/errors", object: lost_item %>

      <div class="row g-3">
        <div class="col-md-8" data-controller="field-limit" data-field-limit-max-chars-value="<%= ListingTextLimits::TITLE_MAX_LENGTH %>">
          <%= f.label :title, "Title *", class: "form-label" %>
          <%= f.text_field :title, class: "form-control", required: true, maxlength: ListingTextLimits::TITLE_MAX_LENGTH, placeholder: "e.g., Black North Face backpack", data: { field_limit_target: "field", action: "input->field-limit#update" } %>
          <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
        </div>
        <div class="col-md-4">
          <%= f.label :category, "Category *", class: "form-label" %>
          <%= f.select :category, LostItem::CATEGORIES, { prompt: "Select a category" }, class: "form-select", required: true %>
        </div>
        <div class="col-12" data-controller="field-limit" data-field-limit-max-chars-value="<%= ListingTextLimits::CUSTOM_CATEGORY_MAX_LENGTH %>">
          <%= f.label :custom_category, "If category is Other, specify", class: "form-label" %>
          <%= f.text_field :custom_category, class: "form-control", placeholder: "e.g., Musical instrument, Kitchenware", maxlength: ListingTextLimits::CUSTOM_CATEGORY_MAX_LENGTH, data: { field_limit_target: "field", action: "input->field-limit#update" } %>
          <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
        </div>

        <div class="col-12" data-controller="field-limit" data-field-limit-max-words-value="<%= ListingTextLimits::DESCRIPTION_MAX_WORDS %>">
          <%= f.label :description, "Description *", class: "form-label" %>
          <%= f.text_area :description, class: "form-control", rows: 4, required: true, placeholder: "Distinctive marks, contents, lock combination hints you are comfortable sharing…", data: { field_limit_target: "field", action: "input->field-limit#update" } %>
          <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
        </div>

        <div class="col-md-6" data-controller="field-limit" data-field-limit-max-words-value="<%= ListingTextLimits::LOCATION_MAX_WORDS %>">
          <%= f.label :location_lost, "Location lost *", class: "form-label" %>
          <%= f.text_field :location_lost, class: "form-control", required: true, placeholder: "Building, room, shuttle stop…", data: { field_limit_target: "field", action: "input->field-limit#update" } %>
          <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
        </div>
        <div class="col-md-6">
          <%= f.label :date_lost, "Date lost *", class: "form-label" %>
          <%= f.date_field :date_lost, class: "form-control", required: true %>
        </div>

        <div class="col-md-6" data-controller="field-limit" data-field-limit-max-chars-value="<%= ListingTextLimits::NAME_MAX_LENGTH %>">
          <%= f.label :contact_name, "Your name *", class: "form-label" %>
          <%= f.text_field :contact_name, class: "form-control", required: true, maxlength: ListingTextLimits::NAME_MAX_LENGTH, data: { field_limit_target: "field", action: "input->field-limit#update" } %>
          <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
        </div>
        <div class="col-md-6">
          <%= f.label :contact_email, "Contact email *", class: "form-label" %>
          <%= f.email_field :contact_email, class: "form-control", required: true %>
        </div>

        <div class="col-md-4">
          <%= f.label :status, "Status *", class: "form-label" %>
          <%= f.select :status, LostItem::STATUSES.map { |s| [s.titleize, s] }, {}, class: "form-select" %>
        </div>
        <div class="col-12">
          <%= render "application/listing_photo_upload", form: f, record: lost_item %>
        </div>
        <div class="col-md-8">
          <%= f.label :image_url, "Or image URL (optional)", class: "form-label" %>
          <%= f.text_field :image_url, class: "form-control", placeholder: "https://…" %>
        </div>

        <div class="col-md-4" data-controller="field-limit" data-field-limit-max-chars-value="<%= ListingTextLimits::COLOR_BRAND_MAX_LENGTH %>">
          <%= f.label :color, "Color (optional)", class: "form-label" %>
          <%= f.text_field :color, class: "form-control", maxlength: ListingTextLimits::COLOR_BRAND_MAX_LENGTH, data: { field_limit_target: "field", action: "input->field-limit#update" } %>
          <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
        </div>
        <div class="col-md-4" data-controller="field-limit" data-field-limit-max-chars-value="<%= ListingTextLimits::COLOR_BRAND_MAX_LENGTH %>">
          <%= f.label :brand, "Brand (optional)", class: "form-label" %>
          <%= f.text_field :brand, class: "form-control", maxlength: ListingTextLimits::COLOR_BRAND_MAX_LENGTH, data: { field_limit_target: "field", action: "input->field-limit#update" } %>
          <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
        </div>
        <div class="col-md-4" data-controller="field-limit" data-field-limit-max-words-value="<%= ListingTextLimits::REWARD_MAX_WORDS %>">
          <%= f.label :reward, "Reward (optional)", class: "form-label" %>
          <%= f.text_field :reward, class: "form-control", placeholder: "Coffee, thanks, etc.", data: { field_limit_target: "field", action: "input->field-limit#update" } %>
          <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4 d-flex flex-column flex-sm-row flex-wrap gap-2 nu-cta-group">
    <%= f.submit lost_item.persisted? ? "Update listing" : "Post lost item", class: "btn btn-primary nu-pill-btn" %>
    <%= link_to "Cancel", lost_item.persisted? ? lost_item_path(lost_item) : lost_items_path, class: "btn btn-outline-secondary nu-pill-btn" %>
  </div>
<% end %>
