<% flash.each do |type, message| %>
  <% next if message.blank? %>
  <% klass = type.to_s == "alert" ? "alert-danger" : "alert-success" %>
  <div class="alert <%= klass %> alert-dismissible fade show nu-card" role="alert">
    <%= message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>
