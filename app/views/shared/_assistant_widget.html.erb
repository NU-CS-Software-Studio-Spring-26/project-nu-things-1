<div class="nu-assistant-widget"
     data-controller="assistant-widget"
     data-assistant-widget-open-class="nu-assistant-widget--open">
  <button type="button"
          class="nu-assistant-fab btn shadow"
          data-action="assistant-widget#toggle"
          aria-expanded="false"
          aria-controls="assistant-panel"
          aria-label="Open AI Finder chat">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15a4 4 0 0 1-4 4H8l-5 3 1.5-4.5A4 4 0 0 1 4 15V7a4 4 0 0 1 4-4h9a4 4 0 0 1 4 4z"/>
      <path d="M9 10h.01M12 10h.01M15 10h.01"/>
    </svg>
  </button>

  <div id="assistant-panel"
       class="nu-assistant-panel card nu-card shadow-lg d-none"
       data-assistant-widget-target="panel"
       role="dialog"
       aria-label="AI Finder chat"
       aria-modal="true">
    <div class="nu-assistant-panel__header card-header d-flex align-items-center justify-content-between py-2 px-3">
      <div>
        <strong class="text-purple">AI Finder</strong>
        <p class="small text-muted mb-0">Search lost, found, rentals &amp; marketplace</p>
      </div>
      <div class="d-flex align-items-center gap-1">
        <% if assistant_chat_messages.any? %>
          <%= button_to clear_assistant_path,
                        method: :delete,
                        class: "btn btn-sm btn-outline-secondary",
                        form: { data: { turbo_stream: true } },
                        title: "Clear chat" do %>
            Clear
          <% end %>
        <% end %>
        <button type="button"
                class="btn btn-sm btn-outline-secondary"
                data-action="assistant-widget#close"
                aria-label="Close chat">
          ×
        </button>
      </div>
    </div>

    <div class="nu-assistant-panel__body card-body p-3 d-flex flex-column gap-2">
      <div id="assistant-messages"
           class="nu-assistant-log d-flex flex-column gap-3"
           data-assistant-widget-target="log"
           role="log"
           aria-live="polite">
        <% if assistant_chat_messages.empty? %>
          <%= render "assistant/empty_state" %>
        <% else %>
          <% assistant_chat_messages.each do |message| %>
            <%= render "assistant/message", message: message, widget: true %>
          <% end %>
        <% end %>
      </div>

      <div id="assistant-form-errors"></div>

      <% unless assistant_gemini_configured? %>
        <div class="alert alert-warning py-2 px-3 small mb-0" role="alert">
          Set <code>GEMINI_API_KEY</code> to enable search.
        </div>
      <% end %>

      <%= form_with url: assistant_messages_path,
                    method: :post,
                    data: { turbo_stream: true, action: "turbo:submit-end->assistant-widget#afterSubmit" },
                    class: "nu-assistant-form mt-1" do %>
        <label for="assistant-widget-message" class="visually-hidden">Message</label>
        <textarea name="message"
                  id="assistant-widget-message"
                  class="form-control form-control-sm mb-2"
                  rows="2"
                  required
                  maxlength="1000"
                  placeholder="e.g. tent, lost backpack, cheap textbook"
                  <%= "disabled" unless assistant_gemini_configured? %>></textarea>
        <%= submit_tag "Search",
                         class: "btn btn-primary btn-sm nu-pill-btn w-100",
                         disabled: !assistant_gemini_configured? %>
      <% end %>
    </div>
  </div>
</div>
