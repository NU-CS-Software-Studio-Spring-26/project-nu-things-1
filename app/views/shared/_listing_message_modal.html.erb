<%# locals: listing_title:, form_url:, message_param_key: (optional hidden id key not needed when url includes id) %>
<div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-5 text-purple" id="contactModalLabel">Message about "<%= listing_title %>"</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <%= form_with url: form_url, method: :post, local: true, class: "needs-validation" do |f| %>
        <div class="modal-body">
          <p class="small text-muted">Your Northwestern account name and email are shared with the poster in this thread.</p>
          <div class="mb-3">
            <%= f.label :message, "Message", class: "form-label" %>
            <%= f.text_area :message,
                            class: "form-control",
                            required: true,
                            placeholder: "Enter your message",
                            rows: 5,
                            maxlength: ConversationMessage::BODY_MAX_LENGTH %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= f.submit "Send message", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
