<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
  <head>
    <%# Apply saved theme before paint to avoid a bright flash when dark is selected %>
    <script>
      (function () {
        try {
          var t = localStorage.getItem("nu-theme");
          document.documentElement.setAttribute("data-bs-theme", t === "dark" ? "dark" : "light");
        } catch (e) {
          document.documentElement.setAttribute("data-bs-theme", "light");
        }
      })();
    </script>
    <title><%= content_for(:title) || brand_name %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/appicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/applogo.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="<%= brand_color %>">
    <meta name="description" content="<%= brand_name %> — find and post lost or found items at Northwestern">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="<%= brand_name %>">


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.10/index.global.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@fullcalendar/daygrid@6.1.10/index.global.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@fullcalendar/timegrid@6.1.10/index.global.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100 nu-body">
    <!-- Skip to main content link for keyboard navigation (WCAG 2.1 Level AA) -->
    <a href="#main-content" class="skip-to-main-content btn btn-primary btn-sm" id="skip-link">
      Skip to main content
    </a>

    <nav class="navbar navbar-expand-lg navbar-dark nu-navbar shadow-sm mb-4">
      <div class="container nu-shell">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2 fw-semibold nu-brand" do %>
          <%= image_tag "/applogo.png", alt: "", class: "nu-navbar-logo", aria: { hidden: true } %>
          <span><%= brand_name %></span>
        <% end %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Lost", lost_items_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Found", found_items_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Rentals", rental_items_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Marketplace", marketplace_listings_path, class: "nav-link" %></li>
            <% if signed_in? %>
              <li class="nav-item">
                <%= link_to conversations_path, class: "nav-link d-inline-flex align-items-center gap-1" do %>
                  Messages
                  <% unread = unread_conversations_count %>
                  <% if unread.positive? %>
                    <span class="badge rounded-pill bg-warning text-dark"><%= unread %></span>
                  <% end %>
                <% end %>
              </li>
            <% end %>
          </ul>
          <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-2 ms-lg-auto nu-navbar-right">
            <div class="d-flex align-items-center">
              <button type="button"
                      class="btn btn-link text-white p-1 rounded-2 nu-theme-toggle border-0 shadow-none"
                      data-controller="theme-toggle"
                      data-action="click->theme-toggle#toggle"
                      aria-pressed="false"
                      aria-label="Switch color theme">
                <span class="nu-theme-toggle__slot" aria-hidden="true">
                  <span class="nu-theme-toggle__icon" data-theme-toggle-target="moonIcon">
                    <svg class="nu-theme-toggle__svg" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
                      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                  </span>
                  <span class="nu-theme-toggle__icon d-none" data-theme-toggle-target="sunIcon">
                    <svg class="nu-theme-toggle__svg" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
                      <circle cx="12" cy="12" r="4"/>
                      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
                    </svg>
                  </span>
                </span>
              </button>
            </div>
            <% if signed_in? %>
              <span class="navbar-text text-white small mb-0 nu-navbar-greeting">
                Hi, <%= display_user_name(current_user) %>!
              </span>
              <% if signed_in? %>
                <div class="d-none d-lg-block"><%= link_to "Profile", user_path(current_user), class: "nav-link d-inline-block" %></div>
              <% end %>
            <% end %>
            <div class="d-flex flex-column flex-sm-row nu-auth-group gap-2">
              <% if signed_in? %>
                <%= button_to "Sign Out", session_path, method: :delete, class: "btn btn-outline-light btn-sm nu-pill-btn", form: { class: "d-inline" } %>
              <% else %>
                <%= link_to "Sign in", new_session_path, class: "btn btn-outline-light btn-sm nu-pill-btn" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <main id="main-content" role="main" class="container nu-shell flex-grow-1 pb-5">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>

    <footer class="border-top mt-auto py-3 small text-muted nu-footer">
      <div class="container nu-shell d-flex flex-column gap-2">
        <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
          <span><%= brand_name %></span>
          <span>For the Northwestern community. Not affiliated with the University.</span>
        </div>
        <%= render "shared/site_meta_links", extra_class: "nu-footer-meta" %>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    
    <!-- Service Worker Registration for PWA -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then((reg) => {
              console.log('Service worker registered:', reg);
            })
            .catch((err) => {
              console.log('Service worker registration failed:', err);
            });
        });
      }
    </script>
  </body>
</html>
