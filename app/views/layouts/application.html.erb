<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Northwestern Lost and Found Board" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.10/index.global.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@fullcalendar/daygrid@6.1.10/index.global.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@fullcalendar/timegrid@6.1.10/index.global.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100 nu-body">
    <!-- Skip to main content link for keyboard navigation -->
    <a href="#main-content" class="btn btn-primary position-absolute top-0 start-0 m-2" style="z-index: 9999; transform: translateY(-100%); transition: transform 0.2s ease;" tabindex="0" 
       onkeydown="if(event.key==='Enter' || event.key===' ') { this.style.transform = 'translateY(0)'; document.getElementById('main-content').focus(); }" 
       onclick="this.style.transform = 'translateY(0)'; document.getElementById('main-content').focus(); this.style.transform = 'translateY(-100%)' ;">
      Skip to main content
    </a>

    <nav class="navbar navbar-expand-lg navbar-dark nu-navbar shadow-sm mb-4">
      <div class="container nu-shell">
        <%= link_to "NU Things", root_path, class: "navbar-brand fw-semibold nu-brand" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Lost Items", lost_items_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Found Items", found_items_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Rentals", rental_items_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Marketplace", marketplace_listings_path, class: "nav-link" %></li>
            <% if signed_in? %>
              <li class="nav-item"><%= link_to "Profile", user_path(current_user), class: "nav-link" %></li>
            <% end %>
          </ul>
          <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-2 ms-lg-auto">
            <% if signed_in? %>
              <span class="navbar-text text-white small mb-0 nu-navbar-greeting">
                Hi, <%= display_user_name(current_user) %>!
              </span>
            <% end %>
            <div class="d-flex flex-column flex-sm-row nu-cta-group gap-2">
              <%= link_to_new_listing "Post lost item", new_lost_item_path, class: "btn btn-outline-light btn-sm nu-pill-btn" %>
              <%= link_to_new_listing "Post found item", new_found_item_path, class: "btn btn-light btn-sm text-purple nu-pill-btn" %>
              <% if signed_in? %>
                <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-outline-light btn-sm nu-pill-btn", form: { class: "d-inline" } %>
              <% else %>
                <%= link_to "Sign up", new_registration_path, class: "btn btn-outline-light btn-sm nu-pill-btn" %>
                <%= link_to "Sign in", new_session_path, class: "btn btn-outline-light btn-sm nu-pill-btn" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <main id="main-content" role="main" class="container nu-shell flex-grow-1 pb-5">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>

    <footer class="border-top mt-auto py-3 small text-muted nu-footer">
      <div class="container nu-shell d-flex flex-column flex-md-row justify-content-between gap-2">
        <span>Northwestern Lost and Found Board</span>
        <span>For the Northwestern community. Not affiliated with the University.</span>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  </body>
</html>
