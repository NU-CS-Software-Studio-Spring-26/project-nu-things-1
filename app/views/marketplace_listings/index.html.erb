<% content_for :title, page_title("Marketplace") %>

<div class="nu-marketplace">
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h2 class="h2 mb-1 text-purple">Marketplace</h2>
    <p class="nu-section-lead mb-0">Browse items for sale or post what you’re looking to buy.</p>
  </div>
  <%= link_to_new_listing "Post listing", new_marketplace_listing_path, class: "btn btn-primary nu-pill-btn" %>
</div>

<%= turbo_frame_tag "listings", data: { controller: "listing-search" } do %>
  <%= render "application/listing_search_bar", url: marketplace_listings_path, preserve_params: { category: params[:category], listing_type: params[:listing_type] }, input_id: "marketplace-listings-search-q" %>

<div class="card nu-card mb-4">
  <div class="card-body">
    <h6 class="card-title text-purple mb-3">Filter by type</h6>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "All", marketplace_listings_path(category: params[:category], q: params[:q]), class: "btn btn-sm #{params[:listing_type].blank? ? 'btn-primary' : 'btn-outline-primary'}", data: { turbo_frame: "listings" } %>
      <%= link_to "For sale", marketplace_listings_path(listing_type: "for_sale", category: params[:category], q: params[:q]), class: "btn btn-sm #{params[:listing_type] == 'for_sale' ? 'btn-primary' : 'btn-outline-primary'}", data: { turbo_frame: "listings" } %>
      <%= link_to "Wanted", marketplace_listings_path(listing_type: "wanted", category: params[:category], q: params[:q]), class: "btn btn-sm #{params[:listing_type] == 'wanted' ? 'btn-primary' : 'btn-outline-primary'}", data: { turbo_frame: "listings" } %>
    </div>
  </div>
</div>

<div class="card nu-card mb-4">
  <div class="card-body">
    <h6 class="card-title text-purple mb-3">Filter by category</h6>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "All categories", marketplace_listings_path(listing_type: params[:listing_type], q: params[:q]), class: "btn btn-sm #{params[:category].blank? ? 'btn-primary' : 'btn-outline-primary'}", data: { turbo_frame: "listings" } %>
      <% @categories.each do |category| %>
        <%= link_to category, marketplace_listings_path(category: category, listing_type: params[:listing_type], q: params[:q]), class: "btn btn-sm #{params[:category] == category ? 'btn-primary' : 'btn-outline-primary'}", data: { turbo_frame: "listings" } %>
      <% end %>
    </div>
  </div>
</div>

<%= render "application/listing_search_results_summary", count: @marketplace_listings.size %>

<% if @marketplace_listings.any? %>
  <div class="row g-4">
    <% @marketplace_listings.each do |item| %>
      <div class="col-md-6 col-lg-4">
        <%= link_to item, class: "card nu-card nu-clickable-card h-100" do %>
          <% if item.listing_image_available? %>
            <%= listing_image_tag item, alt: item.title, class: "card-img-top nu-listing-index-card-img" %>
          <% else %>
            <%= render "application/listing_image_placeholder", aspect_index_card: true, extra_classes: "card-img-top" %>
          <% end %>

          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
              <h5 class="card-title mb-0 nu-item-title"><%= item.title %></h5>
              <span class="badge <%= marketplace_listing_type_badge_class(item.listing_type) %>"><%= item.listing_type == "wanted" ? "Wanted" : "For sale" %></span>
            </div>

            <p class="card-text text-muted small mb-2"><%= truncate(item.description, length: 80) %></p>

            <div class="mb-2">
              <span class="badge <%= marketplace_category_badge_class(item.category) %>"><%= item.category_label %></span>
              <% if item.condition.present? %>
                <span class="badge text-bg-light border"><%= item.condition %></span>
              <% end %>
            </div>

            <div class="mb-3">
              <% if item.listing_type == "for_sale" %>
                <p class="h5 nu-mp-price mb-1">$<%= number_with_precision(item.price, precision: 2) %></p>
              <% else %>
                <p class="h6 text-purple mb-1">Looking to buy</p>
              <% end %>
              <p class="text-muted small mb-0"><%= item.location %></p>
            </div>

            <div class="d-grid gap-2">
              <span class="btn btn-sm btn-primary nu-card-cta">View details</span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <% if listing_index_filters_active? %>
    <div class="alert nu-soft-alert">
      No results match your search.
      <%= link_to "Clear filters", marketplace_listings_path, class: "alert-link", data: { turbo_frame: "listings", action: "listing-search#clearFilters" } %>
    </div>
  <% else %>
    <div class="alert nu-soft-alert">
    No listings yet. Be the first to <%= link_to_new_listing "post a listing", new_marketplace_listing_path, class: "alert-link" %>.
  </div>
  <% end %>
<% end %>
<% end %>
</div>
