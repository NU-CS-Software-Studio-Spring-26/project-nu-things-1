<% content_for :title, "Marketplace — Northwestern Lost and Found Board" %>

<div class="nu-marketplace">
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="h2 mb-1 text-purple">Marketplace</h1>
    <p class="nu-section-lead mb-0">Browse items for sale or post what you’re looking to buy.</p>
  </div>
  <%= link_to_new_listing "Post listing", new_marketplace_listing_path, class: "btn btn-primary nu-pill-btn" %>
</div>

<div class="card nu-card mb-4">
  <div class="card-body">
    <h6 class="card-title text-purple mb-3">Filter by type</h6>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "All", marketplace_listings_path(category: params[:category]), class: "btn btn-sm #{params[:listing_type].blank? ? 'btn-primary' : 'btn-outline-primary'}" %>
      <%= link_to "For sale", marketplace_listings_path(listing_type: "for_sale", category: params[:category]), class: "btn btn-sm #{params[:listing_type] == 'for_sale' ? 'btn-primary' : 'btn-outline-primary'}" %>
      <%= link_to "Wanted", marketplace_listings_path(listing_type: "wanted", category: params[:category]), class: "btn btn-sm #{params[:listing_type] == 'wanted' ? 'btn-primary' : 'btn-outline-primary'}" %>
    </div>
  </div>
</div>

<div class="card nu-card mb-4">
  <div class="card-body">
    <h6 class="card-title text-purple mb-3">Filter by category</h6>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "All categories", marketplace_listings_path(listing_type: params[:listing_type]), class: "btn btn-sm #{params[:category].blank? ? 'btn-primary' : 'btn-outline-primary'}" %>
      <% @categories.each do |category| %>
        <%= link_to category, marketplace_listings_path(category: category, listing_type: params[:listing_type]), class: "btn btn-sm #{params[:category] == category ? 'btn-primary' : 'btn-outline-primary'}" %>
      <% end %>
    </div>
  </div>
</div>

<% if @marketplace_listings.any? %>
  <div class="row g-4">
    <% @marketplace_listings.each do |item| %>
      <div class="col-md-6 col-lg-4">
        <div class="card nu-card h-100">
          <% if item.listing_image_available? %>
            <%= listing_image_tag item, alt: item.title, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
          <% else %>
            <%= render "application/listing_image_placeholder", height: "200px", extra_classes: "card-img-top" %>
          <% end %>

          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
              <h5 class="card-title mb-0"><%= link_to item.title, item, class: "text-decoration-none" %></h5>
              <span class="badge <%= marketplace_listing_type_badge_class(item.listing_type) %>"><%= item.listing_type == "wanted" ? "Wanted" : "For sale" %></span>
            </div>

            <p class="card-text text-muted small mb-2"><%= truncate(item.description, length: 80) %></p>

            <div class="mb-2">
              <span class="badge <%= marketplace_category_badge_class(item.category) %>"><%= item.category_label %></span>
              <% if item.condition.present? %>
                <span class="badge text-bg-light border"><%= item.condition %></span>
              <% end %>
            </div>

            <div class="mb-3">
              <% if item.listing_type == "for_sale" %>
                <p class="h5 nu-mp-price mb-1">$<%= number_with_precision(item.price, precision: 2) %></p>
              <% else %>
                <p class="h6 text-purple mb-1">Looking to buy</p>
              <% end %>
              <p class="text-muted small mb-0"><%= item.location %></p>
            </div>

            <div class="d-grid gap-2">
              <%= link_to "View details", item, class: "btn btn-sm btn-primary" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert nu-soft-alert">
    No listings yet. Be the first to <%= link_to_new_listing "post a listing", new_marketplace_listing_path, class: "alert-link" %>.
  </div>
<% end %>
</div>
