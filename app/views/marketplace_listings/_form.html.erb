<%= form_with(model: marketplace_listing, local: true, html: { multipart: true }) do |form| %>
  <% if marketplace_listing.errors.any? %>
    <div id="error_explanation" class="alert alert-danger mb-3">
      <h4 class="alert-heading"><%= pluralize(marketplace_listing.errors.count, "error") %> prohibited this listing from being saved:</h4>
      <ul class="mb-0">
        <% marketplace_listing.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card nu-card mb-4">
        <div class="card-body">
          <h5 class="card-title text-purple mb-4">Listing Details</h5>

          <div class="row">
            <div class="col-md-6 mb-3">
              <%= form.label :listing_type, "Type", class: "form-label" %>
              <%= form.select :listing_type,
                              MarketplaceListing::LISTING_TYPES.map { |t| [t == "for_sale" ? "For sale" : "Wanted", t] },
                              { prompt: "Select type" },
                              class: "form-select",
                              required: true %>
            </div>

            <div class="col-md-6 mb-3">
              <%= form.label :category, class: "form-label" %>
              <%= form.select :category, MarketplaceListing::CATEGORIES, { prompt: "Select a category" }, class: "form-select", required: true %>
            </div>
          </div>

          <div class="mb-3" data-controller="field-limit" data-field-limit-max-chars-value="<%= ListingTextLimits::CUSTOM_CATEGORY_MAX_LENGTH %>">
            <%= form.label :custom_category, "If category is Other, specify", class: "form-label" %>
            <%= form.text_field :custom_category, class: "form-control", placeholder: "e.g., Musical instrument, Kitchenware", maxlength: ListingTextLimits::CUSTOM_CATEGORY_MAX_LENGTH, data: { field_limit_target: "field", action: "input->field-limit#update" } %>
            <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
          </div>

          <div class="mb-3" data-controller="field-limit" data-field-limit-max-chars-value="<%= ListingTextLimits::TITLE_MAX_LENGTH %>">
            <%= form.label :title, class: "form-label" %>
            <%= form.text_field :title, class: "form-control", required: true, maxlength: ListingTextLimits::TITLE_MAX_LENGTH, placeholder: "e.g., Desk lamp, iClicker, Winter coat", data: { field_limit_target: "field", action: "input->field-limit#update" } %>
            <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
          </div>

          <div class="mb-3" data-controller="field-limit" data-field-limit-max-words-value="<%= ListingTextLimits::DESCRIPTION_MAX_WORDS %>">
            <%= form.label :description, class: "form-label" %>
            <%= form.text_area :description, class: "form-control", required: true, placeholder: "Include condition, size/model, and any details a buyer/seller should know.", rows: 5, data: { field_limit_target: "field", action: "input->field-limit#update" } %>
            <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <%= form.label :condition, class: "form-label" %>
              <%= form.select :condition, MarketplaceListing::CONDITIONS, { prompt: "Select condition (optional)" }, class: "form-select" %>
            </div>

            <div class="col-md-6 mb-3">
              <%= form.label :price, "Price (for sale)", class: "form-label" %>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <%= form.number_field :price, class: "form-control", step: "0.01", placeholder: "0.00" %>
              </div>
              <small class="text-muted">Required for “For sale”. Optional for “Wanted”.</small>
            </div>
          </div>

          <div class="mb-3">
            <%= render "application/listing_photo_upload", form: form, record: marketplace_listing %>
          </div>
          <div class="mb-3">
            <%= form.label :image_url, "Or photo URL (optional)", class: "form-label" %>
            <%= form.text_field :image_url, class: "form-control", placeholder: "https://example.com/image.jpg" %>
          </div>

          <div class="mb-3" data-controller="field-limit" data-field-limit-max-words-value="<%= ListingTextLimits::LOCATION_MAX_WORDS %>">
            <%= form.label :location, class: "form-label" %>
            <%= form.text_field :location, class: "form-control", required: true, placeholder: "e.g., Northwestern Campus, Norris, Tech building", data: { field_limit_target: "field", action: "input->field-limit#update" } %>
            <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card nu-card mb-4">
        <div class="card-body">
          <h5 class="card-title text-purple mb-4">Contact Information</h5>

          <div class="mb-3" data-controller="field-limit" data-field-limit-max-chars-value="<%= ListingTextLimits::NAME_MAX_LENGTH %>">
            <%= form.label :contact_name, "Your name", class: "form-label" %>
            <%= form.text_field :contact_name, class: "form-control", required: true, maxlength: ListingTextLimits::NAME_MAX_LENGTH, data: { field_limit_target: "field", action: "input->field-limit#update" } %>
            <small class="text-muted d-block mt-1" data-field-limit-target="count" aria-live="polite"></small>
          </div>

          <div class="mb-3">
            <%= form.label :contact_email, "Your email", class: "form-label" %>
            <%= form.email_field :contact_email, class: "form-control", required: true %>
          </div>

          <div class="mb-3">
            <%= form.label :contact_phone, "Your phone (optional)", class: "form-label" %>
            <%= form.telephone_field :contact_phone, class: "form-control", placeholder: "(555) 123-4567" %>
          </div>
        </div>
      </div>

      <div class="card nu-card">
        <div class="card-body">
          <h5 class="card-title text-purple mb-4">Status</h5>

          <div class="mb-3">
            <%= form.label :status, class: "form-label" %>
            <%= form.select :status, MarketplaceListing::STATUSES, {}, class: "form-select" %>
          </div>

          <small class="text-muted">
            <strong>active:</strong> Visible in marketplace<br>
            <strong>completed:</strong> Deal completed<br>
            <strong>inactive:</strong> Hidden from marketplace
          </small>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4 mb-3">
    <div class="d-flex gap-2">
      <%= form.submit class: "btn btn-primary" %>
      <%= link_to "Cancel", marketplace_listings_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>
<% end %>

