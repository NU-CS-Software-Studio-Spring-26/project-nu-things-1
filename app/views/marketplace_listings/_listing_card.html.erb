<div class="col-md-6 col-lg-4">
  <%= link_to item, class: "card nu-card nu-clickable-card h-100", data: { turbo_frame: "_top" } do %>
    <%= render_listing_image item, variant: :index_card %>

    <div class="card-body d-flex flex-column">
      <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
        <h5 class="card-title mb-0 nu-item-title"><%= item.title %></h5>
        <span class="badge <%= marketplace_listing_type_badge_class(item.listing_type) %>"><%= item.listing_type == "wanted" ? "Wanted" : "For sale" %></span>
      </div>

      <p class="card-text text-muted small mb-2"><%= truncate(item.description, length: 80) %></p>

      <div class="mb-2">
        <%= render "application/listing_category_badge", item: item %>
        <% if item.condition.present? %>
          <span class="badge text-bg-light border"><%= item.condition %></span>
        <% end %>
      </div>

      <div class="mb-3">
        <% if item.listing_type == "for_sale" %>
          <p class="h5 nu-mp-price mb-1">$<%= number_with_precision(item.price, precision: 2) %></p>
        <% else %>
          <p class="h6 text-purple mb-1">Looking to buy</p>
        <% end %>
        <%= render "listing_stats", item: item %>
        <p class="text-muted small mb-0 mt-2"><%= item.location %></p>
      </div>

      <div class="d-grid gap-2 mt-auto">
        <span class="btn btn-sm btn-primary nu-card-cta">View details</span>
      </div>
    </div>
  <% end %>
</div>
