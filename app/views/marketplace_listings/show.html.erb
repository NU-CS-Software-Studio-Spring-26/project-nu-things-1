<% content_for :title, "#{@marketplace_listing.title} — Marketplace Listing" %>

<div class="nu-marketplace">
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-3">
  <div>
    <h1 class="h2 mb-2 text-purple"><%= @marketplace_listing.title %></h1>
    <span class="badge <%= marketplace_listing_type_badge_class(@marketplace_listing.listing_type) %>">
      <%= @marketplace_listing.listing_type == "wanted" ? "Wanted" : "For sale" %>
    </span>
    <span class="badge <%= marketplace_category_badge_class(@marketplace_listing.category) %> ms-1"><%= @marketplace_listing.category_label %></span>
    <% if @marketplace_listing.condition.present? %>
      <span class="badge text-bg-light border ms-1"><%= @marketplace_listing.condition %></span>
    <% end %>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to "Back to marketplace", marketplace_listings_path, class: "btn btn-outline-secondary btn-sm" %>
    <% if can_edit_post?(@marketplace_listing) %>
      <%= link_to "Edit", edit_marketplace_listing_path(@marketplace_listing), class: "btn btn-primary btn-sm" %>
    <% end %>
    <% if admin? %>
      <%= button_to "Delete", @marketplace_listing, method: :delete, class: "btn btn-danger btn-sm", form: { data: { turbo_confirm: "Delete this listing?" } } %>
    <% end %>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card nu-card mb-4">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase mb-3">Photo</h2>
        <% if @marketplace_listing.listing_image_available? %>
          <%= listing_image_tag @marketplace_listing, alt: @marketplace_listing.title, class: "nu-item-img d-block mx-auto" %>
        <% else %>
          <%= render "application/listing_image_placeholder", height: "300px", extra_classes: "rounded nu-listing-image-placeholder--in-body" %>
        <% end %>
      </div>
    </div>

    <div class="card nu-card">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase">Description</h2>
        <p class="mb-4"><%= simple_format(@marketplace_listing.description) %></p>

        <dl class="row mb-0">
          <dt class="col-sm-4">Location</dt>
          <dd class="col-sm-8"><%= @marketplace_listing.location %></dd>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <% if @marketplace_listing.listing_type == "for_sale" %>
      <div class="card nu-card mb-3">
        <div class="card-body">
          <h2 class="h6 text-muted text-uppercase mb-3">Price</h2>
          <p class="h3 nu-mp-price mb-0">$<%= number_with_precision(@marketplace_listing.price, precision: 2) %></p>
        </div>
      </div>
    <% else %>
      <div class="card nu-card mb-3">
        <div class="card-body">
          <h2 class="h6 text-muted text-uppercase mb-2">Wanted</h2>
          <p class="text-muted small mb-0">This person is looking to buy this item. Reach out to coordinate details and pricing.</p>
        </div>
      </div>
    <% end %>

    <% if signed_in? %>
      <div class="card nu-card mb-3">
        <div class="card-body">
          <h2 class="h6 text-muted text-uppercase">Contact Poster</h2>
          <p class="mb-1"><strong><%= @marketplace_listing.contact_name %></strong></p>
          <p class="mb-2"><%= mail_to @marketplace_listing.contact_email, @marketplace_listing.contact_email, class: "link-primary" %></p>
          <% if @marketplace_listing.contact_phone.present? %>
            <p class="mb-3"><%= @marketplace_listing.contact_phone %></p>
          <% end %>
          <button type="button" class="btn btn-primary w-100" data-bs-toggle="modal" data-bs-target="#contactModal">Send a message</button>
        </div>
      </div>
    <% else %>
      <div class="card nu-card mb-3">
        <div class="card-body">
          <h2 class="h6 text-muted text-uppercase">Contact Poster</h2>
          <p class="text-muted small mb-3">Sign in with your Northwestern email to view contact details and send a message.</p>
          <%= link_to "Sign in", new_session_path, class: "btn btn-primary w-100" %>
        </div>
      </div>
    <% end %>

    <div class="card nu-card">
      <div class="card-body">
        <h2 class="h6 text-muted text-uppercase mb-2">Payment</h2>
        <p class="text-muted small mb-0">Contact each other to arrange payment (cash, Venmo, Zelle) and a safe pickup location.</p>
      </div>
    </div>
  </div>
</div>

<% if signed_in? %>
  <!-- Contact Modal -->
  <div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h1 class="modal-title fs-5 text-purple" id="contactModalLabel">Message about "<%= @marketplace_listing.title %>"</h1>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <%= form_with url: create_marketplace_listing_contact_path, method: :post, local: true, class: "needs-validation" do |f| %>
          <div class="modal-body">
            <%= hidden_field_tag :marketplace_listing_id, @marketplace_listing.id %>

            <div class="mb-3">
              <%= f.label :sender_name, "Your name", class: "form-label" %>
              <%= f.text_field :sender_name, value: prefilled_sender_name_field, class: "form-control", required: true, placeholder: "Enter your name" %>
            </div>

            <div class="mb-3">
              <%= f.label :sender_email, "Your email", class: "form-label" %>
              <%= f.email_field :sender_email, value: prefilled_sender_email_field, class: "form-control", required: true, placeholder: "Enter your email" %>
            </div>

            <div class="mb-3">
              <%= f.label :message, "Message", class: "form-label" %>
              <%= f.text_area :message, class: "form-control", required: true, placeholder: "Ask about condition, price, availability, pickup, etc.", rows: 5 %>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <%= f.submit "Send message", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
</div>
